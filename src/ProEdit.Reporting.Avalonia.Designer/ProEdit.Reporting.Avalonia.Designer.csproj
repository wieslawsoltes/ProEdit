<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <AvaloniaUseCompiledBindingsByDefault>true</AvaloniaUseCompiledBindingsByDefault>
  </PropertyGroup>
  <PropertyGroup Condition="'$(IsDocFxBuild)' == 'true'">
    <EmitCompilerGeneratedFiles>true</EmitCompilerGeneratedFiles>
    <CompilerGeneratedFilesOutputPath>Generated</CompilerGeneratedFilesOutputPath>
  </PropertyGroup>
  <ItemGroup Condition="'$(IsDocFxBuild)' == 'true'">
    <Compile Remove="Generated\\**\\*.cs" />
  </ItemGroup>
  <ItemGroup Condition="'$(IsDocFxMetadata)' == 'true'">
    <Compile Remove="Generated\\Avalonia.Generators\\**\\*.cs" />
  </ItemGroup>
  <PropertyGroup>
    <PackageDescription>Avalonia designer surfaces for ProEdit reporting.</PackageDescription>
    <PackageTags>proedit;reporting;avalonia;designer;authoring</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Avalonia" />
    <PackageReference Include="Avalonia.Skia" />
    <PackageReference Include="Avalonia.Themes.Fluent" />
    <PackageReference Include="ReactiveUI" />
    <PackageReference Include="ReactiveUI.Avalonia" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\\ProEdit.Reporting.Avalonia.Viewer\\ProEdit.Reporting.Avalonia.Viewer.csproj" />
    <ProjectReference Include="..\\ProEdit.Reporting.Core\\ProEdit.Reporting.Core.csproj" />
    <ProjectReference Include="..\\ProEdit.Reporting.Data\\ProEdit.Reporting.Data.csproj" />
    <ProjectReference Include="..\\ProEdit.Reporting.Expressions\\ProEdit.Reporting.Expressions.csproj" />
  </ItemGroup>
</Project>
