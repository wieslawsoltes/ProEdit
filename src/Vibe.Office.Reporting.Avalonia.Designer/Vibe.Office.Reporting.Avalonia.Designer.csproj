<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <AvaloniaUseCompiledBindingsByDefault>true</AvaloniaUseCompiledBindingsByDefault>
  </PropertyGroup>
  <PropertyGroup Condition="'$(IsDocFxBuild)' == 'true'">
    <EmitCompilerGeneratedFiles>true</EmitCompilerGeneratedFiles>
    <CompilerGeneratedFilesOutputPath>Generated</CompilerGeneratedFilesOutputPath>
  </PropertyGroup>
  <ItemGroup Condition="'$(IsDocFxBuild)' == 'true'">
    <Compile Remove="Generated\\**\\*.cs" />
  </ItemGroup>
  <ItemGroup Condition="'$(IsDocFxMetadata)' == 'true'">
    <Compile Remove="Generated\\Avalonia.Generators\\**\\*.cs" />
  </ItemGroup>
  <PropertyGroup>
    <PackageDescription>Avalonia designer surfaces for VibeOffice reporting.</PackageDescription>
    <PackageTags>vibeoffice;reporting;avalonia;designer;authoring</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Avalonia" />
    <PackageReference Include="Avalonia.Skia" />
    <PackageReference Include="Avalonia.Themes.Fluent" />
    <PackageReference Include="ReactiveUI" />
    <PackageReference Include="ReactiveUI.Avalonia" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\\Vibe.Office.Reporting.Avalonia.Viewer\\Vibe.Office.Reporting.Avalonia.Viewer.csproj" />
    <ProjectReference Include="..\\Vibe.Office.Reporting.Core\\Vibe.Office.Reporting.Core.csproj" />
    <ProjectReference Include="..\\Vibe.Office.Reporting.Data\\Vibe.Office.Reporting.Data.csproj" />
    <ProjectReference Include="..\\Vibe.Office.Reporting.Expressions\\Vibe.Office.Reporting.Expressions.csproj" />
  </ItemGroup>
</Project>
