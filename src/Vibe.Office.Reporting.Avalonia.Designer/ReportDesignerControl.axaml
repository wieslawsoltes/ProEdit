<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:designer="using:Vibe.Office.Reporting.Avalonia.Designer"
             x:Class="Vibe.Office.Reporting.Avalonia.Designer.ReportDesignerControl"
             x:DataType="designer:ReportDesignerViewModel">
  <UserControl.Styles>
    <StyleInclude Source="avares://Vibe.Office.Reporting.Avalonia.Designer/Themes/ReportDesignerTheme.axaml" />
  </UserControl.Styles>

  <Grid RowDefinitions="Auto,*,Auto"
        ColumnDefinitions="292,6,*,6,340">
    <Border Grid.Row="0"
            Grid.ColumnSpan="5"
            Classes="designer-context-bar">
      <Grid ColumnDefinitions="*,Auto,Auto"
            ColumnSpacing="12">
        <StackPanel Spacing="2">
          <TextBlock Classes="designer-panel-title"
                     Text="Design View" />
          <TextBlock Classes="designer-helper"
                     Text="{Binding SelectedObjectTitle}" />
        </StackPanel>

        <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8">
          <Border Classes="designer-status-pill">
            <TextBlock Text="{Binding CurrentSectionName}" />
          </Border>
          <Border Classes="designer-status-pill">
            <TextBlock Text="{Binding SurfaceDisplayText}" />
          </Border>
          <Border Classes="designer-status-pill">
            <TextBlock Text="{Binding StatusMessage}" />
          </Border>
        </StackPanel>

        <StackPanel Grid.Column="2"
                    Orientation="Horizontal"
                    Spacing="8">
          <Button Classes="designer-tool-button"
                  Content="Remove"
                  Command="{Binding RemoveSelectedCommand}"
                  IsEnabled="{Binding CanRemoveSelected}" />
          <Button Classes="designer-tool-button designer-tool-button-primary"
                  Content="Run Preview"
                  Command="{Binding RefreshPreviewCommand}" />
        </StackPanel>
      </Grid>
    </Border>

    <designer:ReportDesignerReportDataPane Grid.Row="1"
                                           Grid.RowSpan="2"
                                           Grid.Column="0" />

    <GridSplitter Grid.Row="1"
                  Grid.RowSpan="2"
                  Grid.Column="1"
                  Classes="designer-splitter"
                  HorizontalAlignment="Stretch"
                  ResizeDirection="Columns" />

    <Border Grid.Row="1"
            Grid.Column="2"
            Classes="designer-main">
      <TabControl Classes="designer-center-tabs"
                  SelectedIndex="{Binding SelectedCenterTabIndex, Mode=TwoWay}">
        <TabItem Header="Design">
          <Grid RowDefinitions="Auto,*"
                RowSpacing="12">
            <Border Classes="designer-section-banner">
              <Grid ColumnDefinitions="*,Auto"
                    ColumnSpacing="12">
                <StackPanel Spacing="2">
                  <TextBlock Classes="designer-panel-title"
                             Text="{Binding CurrentSectionName}" />
                  <TextBlock Classes="designer-helper"
                             Text="{Binding SelectedObjectType}" />
                </StackPanel>
                <TextBlock Grid.Column="1"
                           VerticalAlignment="Center"
                           Text="{Binding SurfaceDisplayText}" />
              </Grid>
            </Border>

            <ScrollViewer Grid.Row="1"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto">
              <Border Classes="designer-surface-stage">
                <Border Classes="designer-page"
                        Width="{Binding SurfaceWidth}"
                        Height="{Binding SurfaceHeight}">
                  <ItemsControl ItemsSource="{Binding DesignItems}">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <Canvas />
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="designer:ReportDesignerCanvasItemViewModel">
                        <Button Canvas.Left="{Binding Left}"
                                Canvas.Top="{Binding Top}"
                                Width="{Binding Width}"
                                Height="{Binding Height}"
                                Padding="8"
                                Command="{Binding SelectCommand}"
                                Background="{Binding FillBrush}"
                                BorderBrush="{Binding BorderBrush}"
                                BorderThickness="2">
                          <StackPanel Spacing="4">
                            <TextBlock FontWeight="SemiBold"
                                       Text="{Binding Label}"
                                       TextWrapping="Wrap" />
                            <TextBlock Classes="designer-helper"
                                       Text="{Binding Summary}"
                                       TextWrapping="Wrap" />
                          </StackPanel>
                        </Button>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </Border>
              </Border>
            </ScrollViewer>
          </Grid>
        </TabItem>

        <TabItem Header="Expressions">
          <Grid ColumnDefinitions="240,*"
                ColumnSpacing="12">
            <ListBox ItemsSource="{Binding ExpressionEntries}"
                     SelectedItem="{Binding SelectedExpressionEntry, Mode=TwoWay}">
              <ListBox.ItemTemplate>
                <DataTemplate x:DataType="designer:ReportDesignerExpressionEntryViewModel">
                  <Border Classes="designer-card">
                    <TextBlock Text="{Binding Label}"
                               TextWrapping="Wrap" />
                  </Border>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>

            <Grid Grid.Column="1"
                  RowDefinitions="Auto,*,Auto"
                  RowSpacing="10">
              <StackPanel Spacing="2">
                <TextBlock Classes="designer-panel-title"
                           Text="{Binding SelectedExpressionLabel}" />
                <TextBlock Classes="designer-helper"
                           Text="{Binding ExpressionStatusMessage}" />
              </StackPanel>

              <TextBox Grid.Row="1"
                       AcceptsReturn="True"
                       MinHeight="220"
                       Text="{Binding SelectedExpressionText, Mode=TwoWay}" />

              <StackPanel Grid.Row="2"
                          Orientation="Horizontal"
                          Spacing="8">
                <Button Classes="designer-tool-button designer-tool-button-primary"
                        Content="Apply Expression"
                        Command="{Binding ApplySelectedExpressionCommand}"
                        IsEnabled="{Binding CanApplyExpression}" />
              </StackPanel>
            </Grid>
          </Grid>
        </TabItem>

        <TabItem Header="Gallery">
          <Grid RowDefinitions="Auto,*"
                RowSpacing="12">
            <StackPanel Spacing="2">
              <TextBlock Classes="designer-panel-title"
                         Text="Template Gallery" />
              <TextBlock Classes="designer-helper"
                         Text="Apply starter layouts and narrative blocks to the current section." />
            </StackPanel>

            <ListBox Grid.Row="1"
                     ItemsSource="{Binding TemplateGalleryItems}"
                     SelectedItem="{Binding SelectedGalleryItem, Mode=TwoWay}">
              <ListBox.ItemTemplate>
                <DataTemplate x:DataType="designer:ReportDesignerTemplateGalleryItemViewModel">
                  <Border Classes="designer-card">
                    <Grid ColumnDefinitions="*,Auto"
                          ColumnSpacing="12">
                      <StackPanel Spacing="4">
                        <Border Classes="designer-tag">
                          <TextBlock Text="{Binding Category}" />
                        </Border>
                        <TextBlock FontWeight="SemiBold"
                                   Text="{Binding Title}" />
                        <TextBlock Classes="designer-helper"
                                   Text="{Binding Description}"
                                   TextWrapping="Wrap" />
                      </StackPanel>
                      <Button Grid.Column="1"
                              Classes="designer-tool-button"
                              VerticalAlignment="Center"
                              Content="Apply"
                              Command="{Binding ApplyCommand}" />
                    </Grid>
                  </Border>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </Grid>
        </TabItem>
      </TabControl>
    </Border>

    <designer:ReportDesignerGroupingPane Grid.Row="2"
                                         Grid.Column="2" />

    <GridSplitter Grid.Row="1"
                  Grid.RowSpan="2"
                  Grid.Column="3"
                  Classes="designer-splitter"
                  HorizontalAlignment="Stretch"
                  ResizeDirection="Columns" />

    <designer:ReportDesignerPropertiesPane Grid.Row="1"
                                           Grid.RowSpan="2"
                                           Grid.Column="4" />
  </Grid>
</UserControl>
