<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:designer="using:Vibe.Office.Reporting.Avalonia.Designer"
             x:Class="Vibe.Office.Reporting.Avalonia.Designer.ReportDesignerControl"
             x:DataType="designer:ReportDesignerViewModel">
  <UserControl.Styles>
    <StyleInclude Source="avares://Vibe.Office.Reporting.Avalonia.Designer/Themes/ReportDesignerTheme.axaml" />
  </UserControl.Styles>

  <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto"
        RowDefinitions="Auto,*,Auto">
    <Border Grid.RowSpan="3"
            Classes="designer-rail">
      <StackPanel Margin="6,8"
                  Spacing="6">
        <Button Theme="{StaticResource DesignerRailButtonTheme}"
                Content="Data"
                Command="{Binding OpenReportDataPaneCommand}" />
        <Button Theme="{StaticResource DesignerRailButtonTheme}"
                Content="Outline"
                Command="{Binding OpenOutlinePaneCommand}" />
        <Button Theme="{StaticResource DesignerRailButtonTheme}"
                Content="Templates"
                Command="{Binding OpenTemplateLibraryPaneCommand}" />
      </StackPanel>
    </Border>

    <Border Grid.Column="1"
            Grid.RowSpan="3"
            Width="{Binding LeftDrawerWidth}"
            Classes="designer-drawer designer-drawer-left"
            IsVisible="{Binding IsLeftDrawerVisible}">
      <Grid RowDefinitions="Auto,*">
        <Border Classes="designer-drawer-header">
          <Grid ColumnDefinitions="*,Auto,Auto"
                ColumnSpacing="6">
            <TextBlock Classes="designer-panel-title"
                       Text="Workspace" />
            <Button Grid.Column="1"
                    Theme="{StaticResource DesignerActionButtonTheme}"
                    Content="Pin"
                    Command="{Binding TogglePinLeftDrawerCommand}" />
            <Button Grid.Column="2"
                    Theme="{StaticResource DesignerActionButtonTheme}"
                    Content="Close"
                    Command="{Binding CloseLeftDrawerCommand}" />
          </Grid>
        </Border>
        <designer:ReportDesignerReportDataPane Grid.Row="1" />
      </Grid>
    </Border>

    <Grid Grid.Column="2"
          RowDefinitions="Auto,*,Auto">
      <Border Classes="designer-canvas-toolbar">
        <Grid ColumnDefinitions="Auto,*,Auto"
              ColumnSpacing="10">
          <StackPanel Orientation="Horizontal"
                      Spacing="6">
            <Border Classes="designer-status-pill">
              <TextBlock Classes="designer-helper"
                         Text="{Binding CurrentSectionName}" />
            </Border>
            <Border Classes="designer-status-pill">
              <TextBlock Classes="designer-helper"
                         Text="{Binding SurfaceDisplayText}" />
            </Border>
            <Border Classes="designer-status-pill"
                    IsVisible="{Binding HasActiveInsertTool}">
              <TextBlock Classes="designer-helper"
                         Text="{Binding ActiveInsertToolDisplayText}" />
            </Border>
          </StackPanel>

          <StackPanel Grid.Column="2"
                      Orientation="Horizontal"
                      HorizontalAlignment="Right"
                      Spacing="6">
            <Button Theme="{StaticResource DesignerActionButtonTheme}"
                    Content="Fit Page"
                    Command="{Binding FitPageCommand}" />
            <Button Theme="{StaticResource DesignerActionButtonTheme}"
                    Content="Actual"
                    Command="{Binding ActualSizeCommand}" />
            <Button Theme="{StaticResource DesignerActionButtonTheme}"
                    Content="-"
                    Command="{Binding ZoomOutCommand}" />
            <ComboBox Classes="designer-editor"
                      Width="108"
                      ItemsSource="{Binding ZoomOptions}"
                      SelectedItem="{Binding SelectedZoomOption, Mode=TwoWay}">
              <ComboBox.ItemTemplate>
                <DataTemplate x:DataType="designer:ReportDesignerChoiceOptionViewModel">
                  <TextBlock Text="{Binding Label}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
            <Button Theme="{StaticResource DesignerActionButtonTheme}"
                    Content="+"
                    Command="{Binding ZoomInCommand}" />
            <ToggleButton Theme="{StaticResource DesignerToolToggleButtonTheme}"
                          IsChecked="{Binding ShowRulers}">
              <TextBlock Text="Rulers" />
            </ToggleButton>
            <ToggleButton Theme="{StaticResource DesignerToolToggleButtonTheme}"
                          IsChecked="{Binding ShowSurfacePreviewBackground}">
              <TextBlock Text="Preview" />
            </ToggleButton>
            <Button Theme="{StaticResource DesignerActionButtonTheme}"
                    Content="Parameters"
                    Command="{Binding OpenParameterLayoutTrayCommand}" />
            <Button Theme="{StaticResource DesignerPrimaryActionButtonTheme}"
                    Content="Run Preview"
                    Command="{Binding RefreshPreviewCommand}" />
          </StackPanel>
        </Grid>
      </Border>

      <Border Grid.Row="1"
              Classes="designer-main designer-canvas-host">
        <designer:ReportDesignerDesignSurface />
      </Border>

      <Border Grid.Row="2"
              Classes="designer-context-tray"
              IsVisible="{Binding IsContextTrayVisible}">
        <Grid RowDefinitions="Auto,*"
              RowSpacing="8">
          <Grid ColumnDefinitions="*,Auto,Auto"
                ColumnSpacing="6">
            <StackPanel Orientation="Horizontal"
                        Spacing="8">
              <Border Classes="designer-status-pill"
                      IsVisible="{Binding ShowGroupingTray}">
                <TextBlock Classes="designer-helper"
                           Text="Grouping" />
              </Border>
              <Border Classes="designer-status-pill"
                      IsVisible="{Binding ShowChartDataTray}">
                <TextBlock Classes="designer-helper"
                           Text="Chart Data" />
              </Border>
              <Border Classes="designer-status-pill"
                      IsVisible="{Binding ShowParameterLayoutTray}">
                <TextBlock Classes="designer-helper"
                           Text="Parameter Layout" />
              </Border>
            </StackPanel>
            <Button Grid.Column="1"
                    Theme="{StaticResource DesignerActionButtonTheme}"
                    Content="Pin"
                    Command="{Binding TogglePinContextTrayCommand}" />
            <Button Grid.Column="2"
                    Theme="{StaticResource DesignerActionButtonTheme}"
                    Content="Close"
                    Command="{Binding CloseContextTrayCommand}" />
          </Grid>

          <Grid Grid.Row="1">
            <designer:ReportDesignerGroupingPane IsVisible="{Binding ShowGroupingTray}" />
            <designer:ReportDesignerChartDataPane IsVisible="{Binding ShowChartDataTray}" />
            <designer:ReportDesignerParameterLayoutPane IsVisible="{Binding ShowParameterLayoutTray}" />
          </Grid>
        </Grid>
      </Border>
    </Grid>

    <Border Grid.Column="3"
            Grid.RowSpan="3"
            Width="{Binding RightDrawerWidth}"
            Classes="designer-drawer designer-drawer-right"
            IsVisible="{Binding IsRightDrawerVisible}">
      <Grid RowDefinitions="Auto,*">
        <Border Classes="designer-drawer-header">
          <Grid ColumnDefinitions="*,Auto,Auto"
                ColumnSpacing="6">
            <TextBlock Classes="designer-panel-title"
                       Text="Inspector" />
            <Button Grid.Column="1"
                    Theme="{StaticResource DesignerActionButtonTheme}"
                    Content="Pin"
                    Command="{Binding TogglePinRightDrawerCommand}" />
            <Button Grid.Column="2"
                    Theme="{StaticResource DesignerActionButtonTheme}"
                    Content="Close"
                    Command="{Binding CloseRightDrawerCommand}" />
          </Grid>
        </Border>
        <designer:ReportDesignerPropertiesPane Grid.Row="1" />
      </Grid>
    </Border>

    <Border Grid.Column="4"
            Grid.RowSpan="3"
            Classes="designer-rail designer-rail-right">
      <StackPanel Margin="6,8"
                  Spacing="6">
        <Button Theme="{StaticResource DesignerRailButtonTheme}"
                Content="Props"
                Command="{Binding OpenPropertiesInspectorCommand}" />
        <Button Theme="{StaticResource DesignerRailButtonTheme}"
                Content="Params"
                Command="{Binding OpenParametersInspectorCommand}" />
        <Button Theme="{StaticResource DesignerRailButtonTheme}"
                Content="Data"
                Command="{Binding OpenDataInspectorCommand}" />
        <Button Theme="{StaticResource DesignerRailButtonTheme}"
                Content="Expr"
                Command="{Binding OpenExpressionsInspectorCommand}" />
      </StackPanel>
    </Border>
  </Grid>
</UserControl>
