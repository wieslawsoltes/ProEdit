<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:designer="using:Vibe.Office.Reporting.Avalonia.Designer"
             x:Class="Vibe.Office.Reporting.Avalonia.Designer.ReportDesignerControl"
             x:DataType="designer:ReportDesignerViewModel">
  <UserControl.Styles>
    <StyleInclude Source="avares://Vibe.Office.Reporting.Avalonia.Designer/Themes/ReportDesignerTheme.axaml" />
  </UserControl.Styles>

  <Grid RowDefinitions="Auto,*,Auto"
        ColumnDefinitions="300,5,*,5,348">
    <Border Grid.Row="0"
            Grid.ColumnSpan="5"
            Classes="designer-command-strip">
      <Grid RowDefinitions="Auto,Auto"
            ColumnDefinitions="*,Auto,Auto"
            ColumnSpacing="12"
            RowSpacing="10">
        <StackPanel Spacing="2">
          <TextBlock Classes="designer-panel-title"
                     Text="Report Designer" />
          <TextBlock Classes="designer-helper"
                     Text="{Binding SelectedObjectTitle}" />
        </StackPanel>

        <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8">
          <Border Classes="designer-status-pill">
            <TextBlock Classes="designer-helper"
                       Text="{Binding CurrentSectionName}" />
          </Border>
          <Border Classes="designer-status-pill">
            <TextBlock Classes="designer-helper"
                       Text="{Binding SurfaceDisplayText}" />
          </Border>
          <Border Classes="designer-status-pill">
            <TextBlock Classes="designer-helper"
                       Text="{Binding StatusMessage}" />
          </Border>
        </StackPanel>

        <StackPanel Grid.Column="2"
                    Orientation="Horizontal"
                    Spacing="8">
          <Button Theme="{StaticResource DesignerActionButtonTheme}"
                  Content="Remove"
                  Command="{Binding RemoveSelectedCommand}"
                  IsEnabled="{Binding CanRemoveSelected}" />
          <Button Theme="{StaticResource DesignerPrimaryActionButtonTheme}"
                  Content="Run Preview"
                  Command="{Binding RefreshPreviewCommand}" />
        </StackPanel>

        <StackPanel Grid.Row="1"
                    Grid.ColumnSpan="3"
                    Orientation="Horizontal"
                    Spacing="8">
          <Border Classes="designer-status-pill">
            <TextBlock Classes="designer-helper"
                       Text="{Binding ActiveInsertToolDisplayText}" />
          </Border>
          <Button Theme="{StaticResource DesignerActionButtonTheme}"
                  Content="Text Box"
                  Command="{Binding BeginInsertTextBoxCommand}" />
          <Button Theme="{StaticResource DesignerActionButtonTheme}"
                  Content="Table"
                  Command="{Binding BeginInsertTablixCommand}" />
          <Button Theme="{StaticResource DesignerActionButtonTheme}"
                  Content="Chart"
                  Command="{Binding BeginInsertChartCommand}" />
          <Button Theme="{StaticResource DesignerActionButtonTheme}"
                  Content="Rectangle"
                  Command="{Binding BeginInsertRectangleCommand}" />
          <Button Theme="{StaticResource DesignerActionButtonTheme}"
                  Content="Line"
                  Command="{Binding BeginInsertLineCommand}" />
          <Button Theme="{StaticResource DesignerActionButtonTheme}"
                  Content="Image"
                  Command="{Binding BeginInsertImageCommand}" />
          <Button Theme="{StaticResource DesignerActionButtonTheme}"
                  Content="Subreport"
                  Command="{Binding BeginInsertSubreportCommand}" />
          <Button Theme="{StaticResource DesignerActionButtonTheme}"
                  Content="Template"
                  Command="{Binding BeginInsertTemplateCommand}" />
          <Button Theme="{StaticResource DesignerActionButtonTheme}"
                  Content="Cancel Tool"
                  Command="{Binding CancelInsertToolCommand}"
                  IsEnabled="{Binding HasActiveInsertTool}" />

          <Border Width="1"
                  Height="28"
                  Background="{DynamicResource DesignerBorderBrush}" />

          <Button Theme="{StaticResource DesignerActionButtonTheme}"
                  Content="Duplicate"
                  Command="{Binding DuplicateSelectedCommand}" />
          <Button Theme="{StaticResource DesignerActionButtonTheme}"
                  Content="Bring Front"
                  Command="{Binding BringSelectedToFrontCommand}" />
          <Button Theme="{StaticResource DesignerActionButtonTheme}"
                  Content="Send Back"
                  Command="{Binding SendSelectedToBackCommand}" />
          <Button Theme="{StaticResource DesignerActionButtonTheme}"
                  Content="Bring Forward"
                  Command="{Binding BringSelectedForwardCommand}" />
          <Button Theme="{StaticResource DesignerActionButtonTheme}"
                  Content="Send Backward"
                  Command="{Binding SendSelectedBackwardCommand}" />
        </StackPanel>
      </Grid>
    </Border>

    <designer:ReportDesignerReportDataPane Grid.Row="1"
                                           Grid.RowSpan="2"
                                           Grid.Column="0" />

    <GridSplitter Grid.Row="1"
                  Grid.RowSpan="2"
                  Grid.Column="1"
                  Classes="designer-splitter"
                  HorizontalAlignment="Stretch"
                  ResizeDirection="Columns" />

    <Border Grid.Row="1"
            Grid.Column="2"
            Classes="designer-main">
      <Grid RowDefinitions="Auto,Auto,*">
        <Border Classes="designer-surface-banner">
          <Grid ColumnDefinitions="*,Auto"
                ColumnSpacing="12">
            <StackPanel Spacing="2">
              <TextBlock Classes="designer-panel-title"
                         Text="{Binding CurrentSectionName}" />
              <TextBlock Classes="designer-helper"
                         Text="{Binding SelectedObjectType}" />
            </StackPanel>
            <TextBlock Grid.Column="1"
                       VerticalAlignment="Center"
                       Classes="designer-helper"
                       Text="{Binding SurfaceDisplayText}" />
          </Grid>
        </Border>

        <designer:ReportDesignerParameterLayoutPane Grid.Row="1"
                                                   IsVisible="{Binding ShowParameterLayoutPane}" />

        <designer:ReportDesignerDesignSurface Grid.Row="2" />
      </Grid>
    </Border>

    <Grid Grid.Row="2"
          Grid.Column="2">
      <designer:ReportDesignerGroupingPane IsVisible="{Binding ShowGroupingPane}" />
      <designer:ReportDesignerChartDataPane IsVisible="{Binding ShowChartDataPane}" />
      <Border Classes="designer-grouping-pane"
              IsVisible="{Binding ShowContextPanePlaceholder}">
        <StackPanel Spacing="4">
          <TextBlock Classes="designer-panel-title"
                     Text="{Binding ContextPanePlaceholderTitle}" />
          <TextBlock Classes="designer-helper"
                     Text="{Binding ContextPanePlaceholderText}"
                     TextWrapping="Wrap" />
        </StackPanel>
      </Border>
    </Grid>

    <GridSplitter Grid.Row="1"
                  Grid.RowSpan="2"
                  Grid.Column="3"
                  Classes="designer-splitter"
                  HorizontalAlignment="Stretch"
                  ResizeDirection="Columns" />

    <designer:ReportDesignerPropertiesPane Grid.Row="1"
                                           Grid.RowSpan="2"
                                           Grid.Column="4" />
  </Grid>
</UserControl>
