<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:designer="using:Vibe.Office.Reporting.Avalonia.Designer"
             x:Class="Vibe.Office.Reporting.Avalonia.Designer.ReportDesignerReportDataPane"
             x:DataType="designer:ReportDesignerViewModel">
  <Border Classes="designer-pane designer-pane-left">
    <TabControl Classes="designer-pane-tabs">
      <TabItem Header="Report Data">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <StackPanel Margin="0,0,4,0"
                      Spacing="10">
            <Border Classes="designer-pane-card">
              <Grid RowDefinitions="Auto,Auto,*"
                    RowSpacing="8">
                <Grid ColumnDefinitions="*,Auto"
                      ColumnSpacing="8">
                  <StackPanel Spacing="2">
                    <TextBlock Classes="designer-panel-title"
                               Text="Parameters" />
                    <TextBlock Classes="designer-helper"
                               Text="Visible and internal report inputs." />
                  </StackPanel>
                  <Button Grid.Column="1"
                          Classes="designer-tool-button"
                          Content="Add"
                          Command="{Binding AddParameterCommand}" />
                </Grid>
                <ListBox Grid.Row="2"
                         Classes="designer-pane-list"
                         ItemsSource="{Binding ParameterEntries}"
                         SelectedItem="{Binding SelectedParameterEntry, Mode=TwoWay}">
                  <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="designer:ReportDesignerSelectionEntryViewModel">
                      <Border Classes="designer-list-item-card">
                        <StackPanel Spacing="2">
                          <TextBlock Classes="designer-label"
                                     Text="{Binding Title}" />
                          <TextBlock Classes="designer-helper"
                                     Text="{Binding Subtitle}"
                                     TextWrapping="Wrap" />
                        </StackPanel>
                      </Border>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </Grid>
            </Border>

            <Border Classes="designer-pane-card">
              <Grid RowDefinitions="Auto,Auto,*"
                    RowSpacing="8">
                <Grid ColumnDefinitions="*,Auto"
                      ColumnSpacing="8">
                  <StackPanel Spacing="2">
                    <TextBlock Classes="designer-panel-title"
                               Text="Data Sources" />
                    <TextBlock Classes="designer-helper"
                               Text="Named connectors and connection bindings." />
                  </StackPanel>
                  <Button Grid.Column="1"
                          Classes="designer-tool-button"
                          Content="Add"
                          Command="{Binding AddDataSourceCommand}" />
                </Grid>
                <ListBox Grid.Row="2"
                         Classes="designer-pane-list"
                         ItemsSource="{Binding DataSourceEntries}"
                         SelectedItem="{Binding SelectedDataSourceEntry, Mode=TwoWay}">
                  <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="designer:ReportDesignerSelectionEntryViewModel">
                      <Border Classes="designer-list-item-card">
                        <StackPanel Spacing="2">
                          <TextBlock Classes="designer-label"
                                     Text="{Binding Title}" />
                          <TextBlock Classes="designer-helper"
                                     Text="{Binding Subtitle}"
                                     TextWrapping="Wrap" />
                        </StackPanel>
                      </Border>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </Grid>
            </Border>

            <Border Classes="designer-pane-card">
              <Grid RowDefinitions="Auto,Auto,*"
                    RowSpacing="8">
                <Grid ColumnDefinitions="*,Auto"
                      ColumnSpacing="8">
                  <StackPanel Spacing="2">
                    <TextBlock Classes="designer-panel-title"
                               Text="Datasets" />
                    <TextBlock Classes="designer-helper"
                               Text="Queries and expected field projections." />
                  </StackPanel>
                  <Button Grid.Column="1"
                          Classes="designer-tool-button"
                          Content="Add"
                          Command="{Binding AddDataSetCommand}" />
                </Grid>
                <ListBox Grid.Row="2"
                         Classes="designer-pane-list"
                         ItemsSource="{Binding DataSetEntries}"
                         SelectedItem="{Binding SelectedDataSetEntry, Mode=TwoWay}">
                  <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="designer:ReportDesignerSelectionEntryViewModel">
                      <Border Classes="designer-list-item-card">
                        <StackPanel Spacing="2">
                          <TextBlock Classes="designer-label"
                                     Text="{Binding Title}" />
                          <TextBlock Classes="designer-helper"
                                     Text="{Binding Subtitle}"
                                     TextWrapping="Wrap" />
                        </StackPanel>
                      </Border>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </Grid>
            </Border>

            <Border Classes="designer-pane-card">
              <Grid RowDefinitions="Auto,Auto,*"
                    RowSpacing="8">
                <Grid ColumnDefinitions="*,Auto"
                      ColumnSpacing="8">
                  <StackPanel Spacing="2">
                    <TextBlock Classes="designer-panel-title"
                               Text="Shared Templates" />
                    <TextBlock Classes="designer-helper"
                               Text="Reusable narrative and document fragments." />
                  </StackPanel>
                  <Button Grid.Column="1"
                          Classes="designer-tool-button"
                          Content="Add"
                          Command="{Binding AddSharedTemplateCommand}" />
                </Grid>
                <ListBox Grid.Row="2"
                         Classes="designer-pane-list"
                         ItemsSource="{Binding SharedTemplateEntries}"
                         SelectedItem="{Binding SelectedSharedTemplateEntry, Mode=TwoWay}">
                  <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="designer:ReportDesignerSelectionEntryViewModel">
                      <Border Classes="designer-list-item-card">
                        <StackPanel Spacing="2">
                          <TextBlock Classes="designer-label"
                                     Text="{Binding Title}" />
                          <TextBlock Classes="designer-helper"
                                     Text="{Binding Subtitle}"
                                     TextWrapping="Wrap" />
                        </StackPanel>
                      </Border>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </Grid>
            </Border>
          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <TabItem Header="Outline">
        <Grid RowDefinitions="Auto,*"
              RowSpacing="10">
          <StackPanel Spacing="2">
            <TextBlock Classes="designer-panel-title"
                       Text="Outline" />
            <TextBlock Classes="designer-helper"
                       Text="Sections, items, and reusable report assets." />
          </StackPanel>

          <TreeView Grid.Row="1"
                    ItemsSource="{Binding ExplorerNodes}"
                    SelectedItem="{Binding SelectedExplorerNode, Mode=TwoWay}">
            <TreeView.ItemTemplate>
              <TreeDataTemplate x:DataType="designer:ReportDesignerExplorerNodeViewModel"
                                ItemsSource="{Binding Children}">
                <StackPanel Orientation="Horizontal"
                            Spacing="8">
                  <Border Classes="designer-tag">
                    <TextBlock Text="{Binding Category}" />
                  </Border>
                  <TextBlock Text="{Binding Label}"
                             TextWrapping="NoWrap" />
                </StackPanel>
              </TreeDataTemplate>
            </TreeView.ItemTemplate>
          </TreeView>
        </Grid>
      </TabItem>
    </TabControl>
  </Border>
</UserControl>
