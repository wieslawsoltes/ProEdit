<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:Vibe.Reporting.App.Controls"
        xmlns:designer="clr-namespace:Vibe.Office.Reporting.Avalonia.Designer;assembly=Vibe.Office.Reporting.Avalonia.Designer"
        xmlns:viewer="clr-namespace:Vibe.Office.Reporting.Avalonia.Viewer;assembly=Vibe.Office.Reporting.Avalonia.Viewer"
        xmlns:vm="using:Vibe.Reporting.App.ViewModels"
        x:Class="Vibe.Reporting.App.MainWindow"
        x:DataType="vm:ReportingStudioViewModel"
        Width="1680"
        Height="1024"
        MinWidth="1280"
        MinHeight="820"
        Title="{Binding WindowTitle}">
  <Grid RowDefinitions="Auto,Auto,*,Auto">
    <controls:ReportingStudioHeaderBar />

    <controls:ReportingStudioCommandBar Grid.Row="1" />

    <Border Grid.Row="2"
            Margin="14,10,14,0"
            Classes="studio-workspace">
      <TabControl Classes="studio-workbench-tabs"
                  SelectedIndex="{Binding SelectedWorkspaceTabIndex, Mode=TwoWay}">
        <TabItem Header="Design">
          <designer:ReportDesignerControl DataContext="{Binding DesignerViewModel}" />
        </TabItem>

        <TabItem Header="Run">
          <viewer:ReportViewerControl DataContext="{Binding ViewerViewModel}" />
        </TabItem>
      </TabControl>
    </Border>

    <controls:ReportingStudioStatusStrip Grid.Row="3" />
  </Grid>
</Window>
