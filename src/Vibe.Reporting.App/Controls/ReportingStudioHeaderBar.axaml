<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Vibe.Reporting.App.ViewModels"
             x:Class="Vibe.Reporting.App.Controls.ReportingStudioHeaderBar"
             x:DataType="vm:ReportingStudioViewModel">
  <Border Classes="studio-title-strip">
    <Grid ColumnDefinitions="Auto,*,Auto"
          ColumnSpacing="16">
      <StackPanel Orientation="Horizontal"
                  VerticalAlignment="Center"
                  Spacing="10">
        <TextBlock Classes="studio-app-title"
                   Text="VibeOffice Reporting" />
        <Border Classes="studio-chip studio-chip-accent">
          <TextBlock Classes="studio-caption"
                     Text="{Binding ActiveDocumentMode}" />
        </Border>
      </StackPanel>

      <StackPanel Grid.Column="1"
                  Spacing="2">
        <TextBlock Classes="studio-document-title"
                   Text="{Binding DesignerViewModel.ReportDefinition.Name}" />
        <TextBlock Classes="studio-path-text"
                   Text="{Binding CurrentPathDisplay}"
                   TextWrapping="NoWrap"
                   TextTrimming="CharacterEllipsis" />
      </StackPanel>

      <StackPanel Grid.Column="2"
                  Orientation="Horizontal"
                  VerticalAlignment="Center"
                  Spacing="8">
        <Border Classes="studio-chip">
          <TextBlock Classes="studio-caption"
                     Text="{Binding PreviewStateText}" />
        </Border>
        <Border Classes="studio-chip">
          <TextBlock Classes="studio-caption"
                     Text="{Binding WorkspaceSummaryText}" />
        </Border>
      </StackPanel>
    </Grid>
  </Border>
</UserControl>
