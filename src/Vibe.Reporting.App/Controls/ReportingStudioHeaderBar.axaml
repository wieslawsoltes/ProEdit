<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Vibe.Reporting.App.ViewModels"
             x:Class="Vibe.Reporting.App.Controls.ReportingStudioHeaderBar"
             x:DataType="vm:ReportingStudioViewModel">
  <Border Classes="studio-headerbar">
    <Grid ColumnDefinitions="Auto,*,Auto"
          ColumnSpacing="16">
      <StackPanel Spacing="4">
        <TextBlock Classes="studio-app-title"
                   Text="VibeOffice Reporting Studio" />
        <StackPanel Orientation="Horizontal"
                    Spacing="8">
          <Border Classes="studio-chip studio-chip-accent">
            <TextBlock Text="{Binding ActiveDocumentMode}" />
          </Border>
          <TextBlock Classes="studio-path-text"
                     Text="{Binding CurrentPathDisplay}"
                     TextWrapping="NoWrap"
                     TextTrimming="CharacterEllipsis"
                     MaxWidth="640" />
        </StackPanel>
      </StackPanel>

      <TextBlock Grid.Column="1"
                 VerticalAlignment="Center"
                 Classes="studio-app-subtitle"
                 Text="Report Builder style authoring shell with design and run workflows." />

      <StackPanel Grid.Column="2"
                  Orientation="Horizontal"
                  VerticalAlignment="Center"
                  Spacing="8">
        <Border Classes="studio-chip">
          <TextBlock Text="{Binding PreviewStateText}" />
        </Border>
        <Border Classes="studio-chip">
          <TextBlock Text="{Binding WorkspaceSummaryText}" />
        </Border>
      </StackPanel>
    </Grid>
  </Border>
</UserControl>
