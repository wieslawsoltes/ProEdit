<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Vibe.Reporting.App.ViewModels"
             x:Class="Vibe.Reporting.App.Controls.ReportingStudioCommandBar"
             x:DataType="vm:ReportingStudioViewModel">
  <Border Classes="studio-command-bar">
    <Grid ColumnDefinitions="Auto,12,Auto,12,Auto,*,Auto"
          ColumnSpacing="0">
      <Border Classes="studio-mode-switch">
        <StackPanel Orientation="Horizontal"
                    Spacing="2">
          <ToggleButton Theme="{StaticResource StudioModeToggleButtonTheme}"
                        IsChecked="{Binding IsDesignMode}"
                        Command="{Binding ShowDesignCommand}">
            <TextBlock Text="Design" />
          </ToggleButton>
          <ToggleButton Theme="{StaticResource StudioModeToggleButtonTheme}"
                        IsChecked="{Binding IsRunMode}"
                        Command="{Binding ShowRunCommand}">
            <TextBlock Text="Run" />
          </ToggleButton>
        </StackPanel>
      </Border>

      <Border Grid.Column="2"
              Classes="studio-command-group">
        <StackPanel Orientation="Horizontal"
                    Spacing="6">
          <Button Theme="{StaticResource StudioCommandButtonTheme}"
                  Content="New"
                  Command="{Binding NewSampleCommand}" />
          <Button Theme="{StaticResource StudioCommandButtonTheme}"
                  Content="Open"
                  Command="{Binding OpenTemplateCommand}" />
          <Button Theme="{StaticResource StudioCommandButtonTheme}"
                  Content="Save"
                  Command="{Binding SaveTemplateCommand}"
                  IsEnabled="{Binding CanSaveTemplate}" />
          <Button Theme="{StaticResource StudioCommandButtonTheme}"
                  Content="Save As"
                  Command="{Binding SaveTemplateAsCommand}"
                  IsEnabled="{Binding HasWorkspace}" />
          <Button Theme="{StaticResource StudioCommandButtonTheme}"
                  Content="Import RDL"
                  Command="{Binding ImportRdlCommand}" />
          <Button Theme="{StaticResource StudioCommandButtonTheme}"
                  Content="Export RDL"
                  Command="{Binding ExportRdlCommand}"
                  IsEnabled="{Binding HasWorkspace}" />
        </StackPanel>
      </Border>

      <Border Grid.Column="4"
              Classes="studio-command-group">
        <StackPanel Orientation="Horizontal"
                    Spacing="6">
          <Button Theme="{StaticResource StudioPrimaryCommandButtonTheme}"
                  Content="Refresh Preview"
                  Command="{Binding RefreshPreviewCommand}"
                  IsEnabled="{Binding HasWorkspace}" />
          <Button Theme="{StaticResource StudioCommandButtonTheme}"
                  Content="Run Report"
                  Command="{Binding RunReportCommand}"
                  IsEnabled="{Binding HasWorkspace}" />
          <Button Theme="{StaticResource StudioCommandButtonTheme}"
                  Content="Reset Layout"
                  Command="{Binding ResetActiveLayoutCommand}" />
        </StackPanel>
      </Border>

      <StackPanel Grid.Column="5"
                  Orientation="Horizontal"
                  HorizontalAlignment="Left"
                  Spacing="6"
                  IsVisible="{Binding IsDesignMode}">
        <Button Theme="{StaticResource StudioToolCommandButtonTheme}"
                Content="Text"
                Command="{Binding DesignerViewModel.BeginInsertTextBoxCommand}" />
        <Button Theme="{StaticResource StudioToolCommandButtonTheme}"
                Content="Table"
                Command="{Binding DesignerViewModel.BeginInsertTablixCommand}" />
        <Button Theme="{StaticResource StudioToolCommandButtonTheme}"
                Content="Chart"
                Command="{Binding DesignerViewModel.BeginInsertChartCommand}" />
        <Button Theme="{StaticResource StudioToolCommandButtonTheme}"
                Content="Rectangle"
                Command="{Binding DesignerViewModel.BeginInsertRectangleCommand}" />
        <Button Theme="{StaticResource StudioToolCommandButtonTheme}"
                Content="Image"
                Command="{Binding DesignerViewModel.BeginInsertImageCommand}" />
        <Button Theme="{StaticResource StudioToolCommandButtonTheme}"
                Content="Subreport"
                Command="{Binding DesignerViewModel.BeginInsertSubreportCommand}" />
        <Button Theme="{StaticResource StudioToolCommandButtonTheme}"
                Content="Template"
                Command="{Binding DesignerViewModel.BeginInsertTemplateCommand}" />
        <Button Theme="{StaticResource StudioToolCommandButtonTheme}"
                Content="Cancel"
                Command="{Binding DesignerViewModel.CancelInsertToolCommand}"
                IsEnabled="{Binding DesignerViewModel.HasActiveInsertTool}" />
      </StackPanel>

      <StackPanel Grid.Column="6"
                  Orientation="Horizontal"
                  HorizontalAlignment="Right"
                  Spacing="6">
        <Border Classes="studio-chip">
          <TextBlock Classes="studio-caption"
                     Text="{Binding PreviewStateText}" />
        </Border>
        <Border Classes="studio-chip">
          <TextBlock Classes="studio-caption"
                     Text="{Binding WorkspaceSummaryText}" />
        </Border>
      </StackPanel>
    </Grid>
  </Border>
</UserControl>
