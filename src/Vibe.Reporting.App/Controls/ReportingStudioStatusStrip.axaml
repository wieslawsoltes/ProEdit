<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Vibe.Reporting.App.ViewModels"
             x:Class="Vibe.Reporting.App.Controls.ReportingStudioStatusStrip"
             x:DataType="vm:ReportingStudioViewModel">
  <Border Classes="studio-status-strip">
    <Grid ColumnDefinitions="*,Auto,Auto,Auto"
          ColumnSpacing="14">
      <TextBlock Text="{Binding StatusMessage}"
                 TextTrimming="CharacterEllipsis" />
      <Border Grid.Column="1"
              Classes="studio-chip">
        <TextBlock Text="{Binding DesignerStatusMessage}" />
      </Border>
      <Border Grid.Column="2"
              Classes="studio-chip">
        <TextBlock Text="{Binding ViewerStatusMessage}" />
      </Border>
      <Border Grid.Column="3"
              Classes="studio-chip studio-chip-accent">
        <TextBlock Text="{Binding DiagnosticsSummaryText}" />
      </Border>
    </Grid>
  </Border>
</UserControl>
