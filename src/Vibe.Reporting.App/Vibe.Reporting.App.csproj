<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <AvaloniaUseCompiledBindingsByDefault>true</AvaloniaUseCompiledBindingsByDefault>
    <IsPackable>false</IsPackable>
  </PropertyGroup>

  <PropertyGroup>
    <PackageDescription>Standalone Avalonia reporting studio for VibeOffice viewer and designer workflows.</PackageDescription>
    <PackageTags>vibeoffice;reporting;avalonia;designer;viewer;studio</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Avalonia" />
    <PackageReference Include="Avalonia.Desktop" />
    <PackageReference Include="Avalonia.Fonts.Inter" />
    <PackageReference Include="Avalonia.Themes.Fluent" />
    <PackageReference Include="ReactiveUI" />
    <PackageReference Include="ReactiveUI.Avalonia" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\\Vibe.Office.Reporting.Avalonia.Designer\\Vibe.Office.Reporting.Avalonia.Designer.csproj" />
    <ProjectReference Include="..\\Vibe.Office.Reporting.Avalonia.Viewer\\Vibe.Office.Reporting.Avalonia.Viewer.csproj" />
    <ProjectReference Include="..\\Vibe.Office.Reporting.Core\\Vibe.Office.Reporting.Core.csproj" />
    <ProjectReference Include="..\\Vibe.Office.Reporting.Data\\Vibe.Office.Reporting.Data.csproj" />
    <ProjectReference Include="..\\Vibe.Office.Reporting.Rdl\\Vibe.Office.Reporting.Rdl.csproj" />
    <ProjectReference Include="..\\Vibe.Office.Reporting.Serialization\\Vibe.Office.Reporting.Serialization.csproj" />
  </ItemGroup>
</Project>
