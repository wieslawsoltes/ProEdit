<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:flow="clr-namespace:Vibe.Office.FlowDocument.Avalonia;assembly=Vibe.Office.FlowDocument.Avalonia"
             xmlns:fd="clr-namespace:Vibe.Office.FlowDocument;assembly=Vibe.Office.FlowDocument"
             x:Class="Vibe.FlowDocument.App.Samples.SimpleFlowExamplePage">
  <UserControl.Resources>
    <fd:FlowDocument x:Key="VerbatimDocument"
                     PageWidth="680"
                     PageHeight="960"
                     PagePadding="48,48,48,48">
      <fd:Paragraph>
        <fd:Bold>
          <fd:Run Text="Some bold text in the paragraph." />
        </fd:Bold>
        <fd:Run Text=" Some text that is not bold." />
      </fd:Paragraph>

      <fd:List>
        <fd:ListItem>
          <fd:Paragraph>
            <fd:Run Text="ListItem 1" />
          </fd:Paragraph>
        </fd:ListItem>
        <fd:ListItem>
          <fd:Paragraph>
            <fd:Run Text="ListItem 2" />
          </fd:Paragraph>
        </fd:ListItem>
        <fd:ListItem>
          <fd:Paragraph>
            <fd:Run Text="ListItem 3" />
          </fd:Paragraph>
        </fd:ListItem>
      </fd:List>
    </fd:FlowDocument>

    <fd:FlowDocument x:Key="AdaptedDocument"
                     PageWidth="680"
                     PageHeight="960"
                     PagePadding="48,48,48,48">
      <fd:Paragraph>
        <fd:Bold>
          <fd:Run Text="Some bold text in the paragraph." />
        </fd:Bold>
        <fd:Run Text=" Some text that is not bold." />
      </fd:Paragraph>

      <fd:List MarkerStyle="Disc">
        <fd:ListItem>
          <fd:Paragraph>
            <fd:Run Text="ListItem 1" />
          </fd:Paragraph>
        </fd:ListItem>
        <fd:ListItem>
          <fd:Paragraph>
            <fd:Run Text="ListItem 2" />
          </fd:Paragraph>
        </fd:ListItem>
        <fd:ListItem>
          <fd:Paragraph>
            <fd:Run Text="ListItem 3" />
          </fd:Paragraph>
        </fd:ListItem>
      </fd:List>
    </fd:FlowDocument>
  </UserControl.Resources>

  <Grid RowDefinitions="Auto,*" ColumnDefinitions="*,*">
    <Border Grid.ColumnSpan="2" Background="#1F2333" Padding="10">
      <StackPanel Spacing="2">
        <TextBlock Text="SimpleFlowExampleWholePage" Foreground="#F6F8FF" FontSize="15" FontWeight="SemiBold" />
        <TextBlock Text="FlowDocument overview sample" Foreground="#C9CFDE" FontSize="12" />
      </StackPanel>
    </Border>

    <Border Grid.Row="1" Grid.Column="0" Margin="12,12,6,12" Background="#FFFFFF" BorderBrush="#CFD5E7" BorderThickness="1" CornerRadius="6">
      <Grid RowDefinitions="Auto,*">
        <Border Background="#EEF1F8" Padding="8" BorderBrush="#CFD5E7" BorderThickness="0,0,0,1">
          <TextBlock Text="Verbatim" FontWeight="SemiBold" />
        </Border>
        <flow:FlowDocumentView Grid.Row="1"
                               Margin="8"
                               FlowDocument="{StaticResource VerbatimDocument}"
                               UsePagination="True"
                               ZoomFactor="1"
                               Background="#F8F9FD"
                               InlineUiPlaceholderText="[Inline UI]"
                               BlockUiPlaceholderText="[Block UI]" />
      </Grid>
    </Border>

    <Border Grid.Row="1" Grid.Column="1" Margin="6,12,12,12" Background="#FFFFFF" BorderBrush="#CFD5E7" BorderThickness="1" CornerRadius="6">
      <Grid RowDefinitions="Auto,*">
        <Border Background="#EEF1F8" Padding="8" BorderBrush="#CFD5E7" BorderThickness="0,0,0,1">
          <TextBlock Text="Avalonia-adapted" FontWeight="SemiBold" />
        </Border>
        <flow:FlowDocumentView Grid.Row="1"
                               Margin="8"
                               FlowDocument="{StaticResource AdaptedDocument}"
                               UsePagination="True"
                               ZoomFactor="1"
                               Background="#F8F9FD"
                               InlineUiPlaceholderText="[Inline UI]"
                               BlockUiPlaceholderText="[Block UI]" />
      </Grid>
    </Border>
  </Grid>
</UserControl>
