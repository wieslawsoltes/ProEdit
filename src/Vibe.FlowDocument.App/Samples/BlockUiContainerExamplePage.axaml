<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:flow="clr-namespace:Vibe.Office.FlowDocument.Avalonia;assembly=Vibe.Office.FlowDocument.Avalonia"
             xmlns:fd="clr-namespace:Vibe.Office.FlowDocument;assembly=Vibe.Office.FlowDocument"
             x:Class="Vibe.FlowDocument.App.Samples.BlockUiContainerExamplePage">
  <UserControl.Resources>
    <fd:FlowDocument x:Key="VerbatimDocument"
                     PageWidth="680"
                     PageHeight="960"
                     PagePadding="48,48,48,48"
                     ColumnWidth="400">
      <fd:Section Background="GhostWhite">
        <fd:Paragraph>
          <fd:Run Text="A UIElement element may be embedded directly in flow content by enclosing it in a BlockUIContainer element." />
        </fd:Paragraph>
        <fd:BlockUIContainer>
          <fd:BlockUIContainer.Child>
            <Button Content="Click me!" />
          </fd:BlockUIContainer.Child>
        </fd:BlockUIContainer>
        <fd:Paragraph>
          <fd:Run Text="The BlockUIContainer element may host no more than one top-level UIElement. However, other UIElements may be nested within the UIElement contained by a BlockUIContainer element." />
        </fd:Paragraph>
        <fd:BlockUIContainer>
          <fd:BlockUIContainer.Child>
            <StackPanel>
              <Label Foreground="Blue" Content="Choose a value:" />
              <ComboBox SelectedIndex="0">
                <ComboBoxItem Content="a" />
                <ComboBoxItem Content="b" />
                <ComboBoxItem Content="c" />
              </ComboBox>
              <Label Foreground="Red" Content="Choose a value:" />
              <StackPanel>
                <RadioButton Content="x" />
                <RadioButton Content="y" />
                <RadioButton Content="z" />
              </StackPanel>
              <Label Content="Enter a value:" />
              <TextBox Text="A text editor embedded in flow content." />
            </StackPanel>
          </fd:BlockUIContainer.Child>
        </fd:BlockUIContainer>
      </fd:Section>
    </fd:FlowDocument>

    <fd:FlowDocument x:Key="AdaptedDocument"
                     PageWidth="680"
                     PageHeight="960"
                     PagePadding="48,48,48,48"
                     ColumnWidth="400">
      <fd:Section Background="GhostWhite">
        <fd:Paragraph>
          <fd:Run Text="Avalonia-adapted variant uses the same structure and relies on FlowDocumentView UI placeholders for hosted controls." />
        </fd:Paragraph>
        <fd:BlockUIContainer>
          <fd:BlockUIContainer.Child>
            <StackPanel>
              <Button Content="Click me!" />
              <ComboBox SelectedIndex="1">
                <ComboBoxItem Content="a" />
                <ComboBoxItem Content="b" />
                <ComboBoxItem Content="c" />
              </ComboBox>
              <TextBox Text="Hosted UI placeholders are emitted by the converter." />
            </StackPanel>
          </fd:BlockUIContainer.Child>
        </fd:BlockUIContainer>
      </fd:Section>
    </fd:FlowDocument>
  </UserControl.Resources>

  <Grid RowDefinitions="Auto,*" ColumnDefinitions="*,*">
    <Border Grid.ColumnSpan="2" Background="#1F2333" Padding="10">
      <StackPanel Spacing="2">
        <TextBlock Text="_BlockUIXAML" Foreground="#F6F8FF" FontSize="15" FontWeight="SemiBold" />
        <TextBlock Text="SpanSnippets sample" Foreground="#C9CFDE" FontSize="12" />
      </StackPanel>
    </Border>

    <Border Grid.Row="1" Grid.Column="0" Margin="12,12,6,12" Background="#FFFFFF" BorderBrush="#CFD5E7" BorderThickness="1" CornerRadius="6">
      <Grid RowDefinitions="Auto,*">
        <Border Background="#EEF1F8" Padding="8" BorderBrush="#CFD5E7" BorderThickness="0,0,0,1">
          <TextBlock Text="Verbatim" FontWeight="SemiBold" />
        </Border>
        <flow:FlowDocumentView Grid.Row="1"
                               Margin="8"
                               FlowDocument="{StaticResource VerbatimDocument}"
                               UsePagination="True"
                               ZoomFactor="1"
                               Background="#F8F9FD"
                               InlineUiPlaceholderText="[Inline UI]"
                               BlockUiPlaceholderText="[Block UI]" />
      </Grid>
    </Border>

    <Border Grid.Row="1" Grid.Column="1" Margin="6,12,12,12" Background="#FFFFFF" BorderBrush="#CFD5E7" BorderThickness="1" CornerRadius="6">
      <Grid RowDefinitions="Auto,*">
        <Border Background="#EEF1F8" Padding="8" BorderBrush="#CFD5E7" BorderThickness="0,0,0,1">
          <TextBlock Text="Avalonia-adapted" FontWeight="SemiBold" />
        </Border>
        <flow:FlowDocumentView Grid.Row="1"
                               Margin="8"
                               FlowDocument="{StaticResource AdaptedDocument}"
                               UsePagination="True"
                               ZoomFactor="1"
                               Background="#F8F9FD"
                               InlineUiPlaceholderText="[Inline UI]"
                               BlockUiPlaceholderText="[Block UI]" />
      </Grid>
    </Border>
  </Grid>
</UserControl>
