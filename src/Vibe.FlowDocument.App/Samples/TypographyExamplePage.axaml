<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:flow="clr-namespace:Vibe.Office.FlowDocument.Avalonia;assembly=Vibe.Office.FlowDocument.Avalonia"
             xmlns:fd="clr-namespace:Vibe.Office.FlowDocument;assembly=Vibe.Office.FlowDocument"
             x:Class="Vibe.FlowDocument.App.Samples.TypographyExamplePage">
  <UserControl.Resources>
    <fd:FlowDocument x:Key="VerbatimDocument"
                     PageWidth="680"
                     PageHeight="960"
                     PagePadding="48,48,48,48">
      <fd:Paragraph TextAlignment="Left" FontSize="18" FontFamily="Palatino Linotype">
        <fd:Run Text="This text has some altered typography characteristics. Note that use of an open type font is necessary for most typographic properties to be effective." />
        <fd:LineBreak />
        <fd:LineBreak />
        <fd:Run Text="0123456789 10 11 12 13" />
        <fd:LineBreak />
        <fd:LineBreak />
        <fd:Run Text="1/2 2/3 3/4" />
      </fd:Paragraph>
      <fd:Paragraph>
        <fd:Run Text="WPF attached typography properties (NumeralStyle, Fraction, Variants) are represented in the adapted pane." />
      </fd:Paragraph>
    </fd:FlowDocument>

    <fd:FlowDocument x:Key="AdaptedDocument"
                     PageWidth="680"
                     PageHeight="960"
                     PagePadding="48,48,48,48">
      <fd:Paragraph TextAlignment="Left" FontSize="18" FontFamily="Palatino Linotype" FontStretch="UltraExpanded">
        <fd:Run Text="This text has some altered typography characteristics. Note that use of an open type font is necessary for most typographic properties to be effective." />
        <fd:LineBreak />
        <fd:LineBreak />
        <fd:Run Text="0123456789 10 11 12 13" />
        <fd:LineBreak />
        <fd:LineBreak />
        <fd:Run BaselineAlignment="Subscript" Text="1/2 2/3 3/4" />
      </fd:Paragraph>
    </fd:FlowDocument>
  </UserControl.Resources>

  <Grid RowDefinitions="Auto,*" ColumnDefinitions="*,*">
    <Border Grid.ColumnSpan="2" Background="#1F2333" Padding="10">
      <StackPanel Spacing="2">
        <TextBlock Text="_TextElement_TypogXAML" Foreground="#F6F8FF" FontSize="15" FontWeight="SemiBold" />
        <TextBlock Text="TextElementSnippets sample" Foreground="#C9CFDE" FontSize="12" />
      </StackPanel>
    </Border>

    <Border Grid.Row="1" Grid.Column="0" Margin="12,12,6,12" Background="#FFFFFF" BorderBrush="#CFD5E7" BorderThickness="1" CornerRadius="6">
      <Grid RowDefinitions="Auto,*">
        <Border Background="#EEF1F8" Padding="8" BorderBrush="#CFD5E7" BorderThickness="0,0,0,1">
          <TextBlock Text="Verbatim" FontWeight="SemiBold" />
        </Border>
        <flow:FlowDocumentView Grid.Row="1"
                               Margin="8"
                               FlowDocument="{StaticResource VerbatimDocument}"
                               UsePagination="True"
                               ZoomFactor="1"
                               Background="#F8F9FD"
                               InlineUiPlaceholderText="[Inline UI]"
                               BlockUiPlaceholderText="[Block UI]" />
      </Grid>
    </Border>

    <Border Grid.Row="1" Grid.Column="1" Margin="6,12,12,12" Background="#FFFFFF" BorderBrush="#CFD5E7" BorderThickness="1" CornerRadius="6">
      <Grid RowDefinitions="Auto,*">
        <Border Background="#EEF1F8" Padding="8" BorderBrush="#CFD5E7" BorderThickness="0,0,0,1">
          <TextBlock Text="Avalonia-adapted" FontWeight="SemiBold" />
        </Border>
        <flow:FlowDocumentView Grid.Row="1"
                               Margin="8"
                               FlowDocument="{StaticResource AdaptedDocument}"
                               UsePagination="True"
                               ZoomFactor="1"
                               Background="#F8F9FD"
                               InlineUiPlaceholderText="[Inline UI]"
                               BlockUiPlaceholderText="[Block UI]" />
      </Grid>
    </Border>
  </Grid>
</UserControl>
