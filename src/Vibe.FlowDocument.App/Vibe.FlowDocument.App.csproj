<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <AvaloniaUseCompiledBindingsByDefault>true</AvaloniaUseCompiledBindingsByDefault>
    <IsPackable>false</IsPackable>
  </PropertyGroup>
  <PropertyGroup>
    <PackageDescription>Sample app showcasing FlowDocumentView.</PackageDescription>
    <PackageTags>vibeoffice;flowdocument;avalonia;sample</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Avalonia" />
    <PackageReference Include="Avalonia.Desktop" />
    <PackageReference Include="Avalonia.Themes.Fluent" />
    <PackageReference Include="Avalonia.Fonts.Inter" />
    <PackageReference Include="ReactiveUI" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Vibe.Office.FlowDocument\Vibe.Office.FlowDocument.csproj" />
    <ProjectReference Include="..\Vibe.Office.FlowDocument.Avalonia\Vibe.Office.FlowDocument.Avalonia.csproj" />
    <ProjectReference Include="..\Vibe.Office.FlowDocument.IO\Vibe.Office.FlowDocument.IO.csproj" />
    <ProjectReference Include="..\Vibe.Office.RichText.Avalonia\Vibe.Office.RichText.Avalonia.csproj" />
  </ItemGroup>
</Project>
