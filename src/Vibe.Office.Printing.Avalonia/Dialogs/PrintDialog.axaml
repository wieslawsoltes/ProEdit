<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Vibe.Office.Printing.Avalonia"
        xmlns:printing="clr-namespace:Vibe.Office.Printing;assembly=Vibe.Office.Printing"
        x:Class="Vibe.Office.Printing.Avalonia.PrintDialog"
        x:DataType="local:PrintDialogViewModel"
        Width="980"
        Height="680"
        MinWidth="860"
        MinHeight="620"
        WindowStartupLocation="CenterOwner"
        Title="Print"
        Background="#ECECEC">
  <Window.Resources>
    <local:PrintEnumDisplayConverter x:Key="PrintEnumDisplayConverter" />
    <local:ByteArrayToBitmapConverter x:Key="ByteArrayToBitmapConverter" />
    <local:StringHasValueConverter x:Key="StringHasValueConverter" />
    <local:EnumEqualsConverter x:Key="EnumEqualsConverter" />
    <local:PreviewSelectionModeConverter x:Key="PreviewSelectionModeConverter" />
    <local:BoolToOpacityConverter x:Key="BoolToOpacityConverter" />
    <ControlTemplate x:Key="SegmentLeftTemplate" TargetType="ToggleButton">
      <Border Background="{TemplateBinding Background}"
              BorderBrush="{TemplateBinding BorderBrush}"
              BorderThickness="{TemplateBinding BorderThickness}"
              CornerRadius="6,0,0,6"
              Padding="{TemplateBinding Padding}">
        <ContentPresenter Content="{TemplateBinding Content}"
                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
      </Border>
    </ControlTemplate>
    <ControlTemplate x:Key="SegmentRightTemplate" TargetType="ToggleButton">
      <Border Background="{TemplateBinding Background}"
              BorderBrush="{TemplateBinding BorderBrush}"
              BorderThickness="{TemplateBinding BorderThickness}"
              CornerRadius="0,6,6,0"
              Padding="{TemplateBinding Padding}">
        <ContentPresenter Content="{TemplateBinding Content}"
                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
      </Border>
    </ControlTemplate>
  </Window.Resources>
  <Window.Styles>
    <Style Selector="ComboBox.print-input">
      <Setter Property="MinHeight" Value="30" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    </Style>
    <Style Selector="TextBox.print-input">
      <Setter Property="MinHeight" Value="28" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="HorizontalContentAlignment" Value="Left" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.print-secondary">
      <Setter Property="MinHeight" Value="30" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.print-footer">
      <Setter Property="MinHeight" Value="30" />
      <Setter Property="MinWidth" Value="90" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="TextBlock.print-label">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="#202124" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="ToggleButton.segment">
      <Setter Property="Background" Value="#F8F8F8" />
      <Setter Property="BorderBrush" Value="#C9CDD3" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="12,4" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="Foreground" Value="#202124" />
    </Style>
    <Style Selector="ToggleButton.segment:checked">
      <Setter Property="Background" Value="#E0E7FF" />
      <Setter Property="BorderBrush" Value="#3B82F6" />
      <Setter Property="Foreground" Value="#1D4ED8" />
    </Style>
    <Style Selector="ToggleButton.segment-left">
      <Setter Property="Template" Value="{StaticResource SegmentLeftTemplate}" />
    </Style>
    <Style Selector="ToggleButton.segment-right">
      <Setter Property="Template" Value="{StaticResource SegmentRightTemplate}" />
    </Style>
    <Style Selector="ListBox.preview-list">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="ListBox.preview-list > ListBoxItem">
      <Setter Property="Padding" Value="0" />
      <Setter Property="Margin" Value="0,0,0,12" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="ListBox.preview-list > ListBoxItem:selected">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
    </Style>
    <Style Selector="ListBox.preview-list > ListBoxItem:selected Border.preview-card">
      <Setter Property="BorderBrush" Value="#3B82F6" />
      <Setter Property="BorderThickness" Value="2" />
    </Style>
  </Window.Styles>

  <Grid RowDefinitions="*,Auto">
    <Grid ColumnDefinitions="280,*">
      <Border Grid.Column="0"
              Background="#F2F2F2"
              BorderBrush="#D6D8DC"
              BorderThickness="0,0,1,0">
        <Grid RowDefinitions="Auto,*">
          <Border Background="#ECECEC"
                  BorderBrush="#D6D8DC"
                  BorderThickness="0,0,0,1"
                  Padding="10">
            <Grid ColumnDefinitions="*,Auto,Auto"
                  ColumnSpacing="6"
                  VerticalAlignment="Center">
              <TextBlock Grid.Column="1"
                         Text="Zoom"
                         VerticalAlignment="Center"
                         Foreground="#5F6368"
                         HorizontalAlignment="Right" />
              <ComboBox Grid.Column="2"
                        ItemsSource="{Binding ZoomOptions}"
                        SelectedItem="{Binding SelectedZoomOption, Mode=TwoWay}"
                        Width="90"
                        Classes="print-input">
                <ComboBox.ItemTemplate>
                  <DataTemplate x:DataType="local:PrintZoomOption">
                    <TextBlock Text="{Binding Label}" />
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>
            </Grid>
          </Border>

          <ScrollViewer Grid.Row="1"
                        VerticalScrollBarVisibility="Auto"
                        Padding="16,12,16,12">
            <ListBox ItemsSource="{Binding PreviewPages}"
                     SelectedItem="{Binding SelectedPreviewPage}"
                     SelectedItems="{Binding SelectedPreviewItems}"
                     SelectionMode="{Binding PreviewSelectionMode, Converter={StaticResource PreviewSelectionModeConverter}}"
                     Classes="preview-list">
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="local:PrintPreviewItem">
                <Border Classes="preview-card"
                        Background="#FFFFFF"
                        BorderBrush="#D0D0D0"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="10"
                        Opacity="{Binding IsIncluded, Converter={StaticResource BoolToOpacityConverter}}">
                  <Grid>
                    <Image x:CompileBindings="False"
                           Source="{Binding Page.ImageBytes, Converter={StaticResource ByteArrayToBitmapConverter}}"
                           Width="{Binding DataContext.PreviewThumbnailWidth, RelativeSource={RelativeSource AncestorType=Window}}"
                           Height="{Binding DataContext.PreviewThumbnailHeight, RelativeSource={RelativeSource AncestorType=Window}}"
                           Stretch="Uniform"
                           StretchDirection="DownOnly"
                           RenderOptions.BitmapInterpolationMode="HighQuality"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Top" />
                    <Border Background="#F2F2F2"
                            CornerRadius="12"
                            Padding="8,4"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Bottom"
                            Margin="4">
                      <TextBlock x:CompileBindings="False"
                                 FontSize="11"
                                 Foreground="#202124">
                        <TextBlock.Text>
                          <MultiBinding StringFormat="Page {0} of {1}">
                            <Binding Path="Page.PageNumber" />
                            <Binding Path="DataContext.TotalPages"
                                     RelativeSource="{RelativeSource AncestorType=Window}" />
                          </MultiBinding>
                        </TextBlock.Text>
                      </TextBlock>
                    </Border>
                  </Grid>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
          </ScrollViewer>
        </Grid>
      </Border>

      <ScrollViewer Grid.Column="1"
                    VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24"
                    Spacing="16"
                    HorizontalAlignment="Stretch">
          <Border Background="#F7F7F7"
                  CornerRadius="8"
                  BorderBrush="#E1E3E6"
                  BorderThickness="1"
                  Padding="12">
            <Grid ColumnDefinitions="Auto,*"
                  RowDefinitions="Auto,Auto"
                  ColumnSpacing="12"
                  RowSpacing="10">
              <TextBlock Text="Printer"
                         Classes="print-label" />
              <ComboBox Grid.Column="1"
                        ItemsSource="{Binding Printers}"
                        SelectedItem="{Binding SelectedPrinter, Mode=TwoWay}"
                        Classes="print-input">
                <ComboBox.ItemTemplate>
                  <DataTemplate x:DataType="printing:PrinterInfo">
                    <TextBlock Text="{Binding DisplayName}" />
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>

              <TextBlock Grid.Row="1"
                         Text="Presets"
                         Classes="print-label" />
              <ComboBox Grid.Row="1"
                        Grid.Column="1"
                        ItemsSource="{Binding PresetOptions}"
                        SelectedItem="{Binding SelectedPreset, Mode=TwoWay}"
                        Classes="print-input">
                <ComboBox.ItemTemplate>
                  <DataTemplate x:DataType="local:PrintPresetOption">
                    <TextBlock Text="{Binding Label}" />
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>
            </Grid>
          </Border>

          <Border Background="#FFFFFF"
                  CornerRadius="8"
                  BorderBrush="#E1E3E6"
                  BorderThickness="1"
                  Padding="12">
            <StackPanel Spacing="10">
              <Grid ColumnDefinitions="Auto,*"
                    ColumnSpacing="12">
                <TextBlock Text="Copies"
                           Classes="print-label" />
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="8"
                            HorizontalAlignment="Right">
                  <TextBox Text="{Binding Copies, Mode=TwoWay}"
                           Classes="print-input"
                           Width="60"
                           HorizontalContentAlignment="Center" />
                  <CheckBox Content="Collate"
                            IsChecked="{Binding Collate, Mode=TwoWay}"
                            VerticalAlignment="Center" />
                </StackPanel>
              </Grid>

              <Border Height="1"
                      Background="#E5E7EB" />

              <Grid ColumnDefinitions="Auto,*"
                    ColumnSpacing="12">
                <TextBlock Text="Pages"
                           Classes="print-label"
                           VerticalAlignment="Top" />
                <StackPanel Grid.Column="1"
                            Spacing="6">
                  <RadioButton Content="{Binding AllPagesLabel}"
                               GroupName="PagesRange"
                               IsChecked="{Binding RangeKind, Mode=TwoWay, Converter={StaticResource EnumEqualsConverter}, ConverterParameter=All}" />
                  <RadioButton Content="Current Page"
                               GroupName="PagesRange"
                               IsChecked="{Binding RangeKind, Mode=TwoWay, Converter={StaticResource EnumEqualsConverter}, ConverterParameter=CurrentPage}" />
                  <StackPanel Orientation="Horizontal"
                              Spacing="8">
                    <RadioButton Content="Range from"
                                 GroupName="PagesRange"
                                 IsChecked="{Binding RangeKind, Mode=TwoWay, Converter={StaticResource EnumEqualsConverter}, ConverterParameter=CustomPages}" />
                    <TextBox Text="{Binding RangeStartText, Mode=TwoWay}"
                             Width="48"
                             IsEnabled="{Binding IsCustomRangeVisible}"
                             Classes="print-input"
                             HorizontalContentAlignment="Center" />
                    <TextBlock Text="to"
                               VerticalAlignment="Center"
                               Foreground="#5F6368" />
                    <TextBox Text="{Binding RangeEndText, Mode=TwoWay}"
                             Width="48"
                             IsEnabled="{Binding IsCustomRangeVisible}"
                             Classes="print-input"
                             HorizontalContentAlignment="Center" />
                  </StackPanel>
                  <RadioButton Content="Selection"
                               GroupName="PagesRange"
                               IsVisible="{Binding IsSelectionRangeAvailable}"
                               IsChecked="{Binding RangeKind, Mode=TwoWay, Converter={StaticResource EnumEqualsConverter}, ConverterParameter=Selection}" />
                  <TextBlock Text="Select pages from the sidebar"
                             FontSize="11"
                             Foreground="#7A7D81"
                             Margin="24,0,0,0"
                             IsVisible="{Binding RangeKind, Converter={StaticResource EnumEqualsConverter}, ConverterParameter=Selection}" />
                  <TextBlock Text="{Binding RangeErrorMessage}"
                             Foreground="#B00020"
                             FontSize="11"
                             IsVisible="{Binding HasRangeError}" />
                </StackPanel>
              </Grid>

              <Border Height="1"
                      Background="#E5E7EB" />

              <Grid ColumnDefinitions="Auto,*"
                    ColumnSpacing="12">
                <TextBlock Text="Double-sided"
                           Classes="print-label" />
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding DuplexOptions}"
                          SelectedItem="{Binding Duplex, Mode=TwoWay}"
                          Classes="print-input">
                  <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="printing:PrintDuplexMode">
                      <TextBlock Text="{Binding ., Converter={StaticResource PrintEnumDisplayConverter}}" />
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>
              </Grid>

              <Border Height="1"
                      Background="#E5E7EB" />

              <Grid ColumnDefinitions="Auto,*"
                    ColumnSpacing="12">
                <TextBlock Text="Paper Size"
                           Classes="print-label" />
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding PaperSizeOptions}"
                          SelectedItem="{Binding SelectedPaperSize, Mode=TwoWay}"
                          Classes="print-input">
                  <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="local:PrintPaperSizeOption">
                      <TextBlock Text="{Binding Label}" />
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>
              </Grid>

              <Border Height="1"
                      Background="#E5E7EB" />

              <Grid ColumnDefinitions="Auto,*"
                    ColumnSpacing="12">
                <TextBlock Text="Orientation"
                           Classes="print-label" />
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal">
                  <ToggleButton Content="Portrait"
                                Classes="segment segment-left"
                                IsChecked="{Binding Orientation, Mode=TwoWay, Converter={StaticResource EnumEqualsConverter}, ConverterParameter=Portrait}" />
                  <ToggleButton Content="Landscape"
                                Classes="segment segment-right"
                                IsChecked="{Binding Orientation, Mode=TwoWay, Converter={StaticResource EnumEqualsConverter}, ConverterParameter=Landscape}" />
                </StackPanel>
              </Grid>

              <Border Height="1"
                      Background="#E5E7EB" />

              <Grid ColumnDefinitions="Auto,*"
                    ColumnSpacing="12">
                <TextBlock Text="Color"
                           Classes="print-label" />
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding ColorOptions}"
                          SelectedItem="{Binding ColorMode, Mode=TwoWay}"
                          Classes="print-input">
                  <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="printing:PrintColorMode">
                      <TextBlock Text="{Binding ., Converter={StaticResource PrintEnumDisplayConverter}}" />
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>
              </Grid>

              <Border Height="1"
                      Background="#E5E7EB" />

              <Grid ColumnDefinitions="Auto,*"
                    ColumnSpacing="12">
                <TextBlock Text="Scale"
                           Classes="print-label" />
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding ScalingOptions}"
                          SelectedItem="{Binding Scaling, Mode=TwoWay}"
                          Classes="print-input">
                  <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="printing:PrintScalingMode">
                      <TextBlock Text="{Binding ., Converter={StaticResource PrintEnumDisplayConverter}}" />
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>
              </Grid>

              <Grid ColumnDefinitions="Auto,*"
                    ColumnSpacing="12"
                    IsVisible="{Binding IsCustomScaleVisible}">
                <TextBlock Text="Custom Scale"
                           FontSize="12"
                           Foreground="#5F6368"
                           VerticalAlignment="Center" />
                <TextBox Grid.Column="1"
                         Text="{Binding CustomScale, Mode=TwoWay}"
                         Classes="print-input"
                         Width="90"
                         HorizontalContentAlignment="Center" />
              </Grid>
            </StackPanel>
          </Border>

          <Border Background="#FFFFFF"
                  CornerRadius="8"
                  BorderBrush="#E1E3E6"
                  BorderThickness="1"
                  Padding="12"
                  IsVisible="{Binding IsPdfOutput}">
            <Grid ColumnDefinitions="Auto,*,Auto"
                  ColumnSpacing="12">
              <TextBlock Text="Save As"
                         Classes="print-label" />
              <TextBox Grid.Column="1"
                       Text="{Binding OutputPath, Mode=TwoWay}"
                       Watermark="Choose PDF output path"
                       Classes="print-input" />
              <Button Grid.Column="2"
                      Content="Browse"
                      Classes="print-secondary"
                      Command="{Binding BrowseOutputCommand}" />
            </Grid>
          </Border>

          <TextBlock Text="{Binding StatusMessage}"
                     Foreground="#5F6368"
                     FontSize="12"
                     TextWrapping="Wrap"
                     IsVisible="{Binding StatusMessage, Converter={StaticResource StringHasValueConverter}}" />
        </StackPanel>
      </ScrollViewer>
    </Grid>

    <Border Grid.Row="1"
            Background="#F5F5F5"
            BorderBrush="#D6D8DC"
            BorderThickness="0,1,0,0"
            Padding="12">
      <Grid ColumnDefinitions="Auto,*,Auto,Auto"
            ColumnSpacing="8"
            VerticalAlignment="Center">
        <ComboBox ItemsSource="{Binding OutputOptions}"
                  SelectedItem="{Binding OutputKind, Mode=TwoWay}"
                  Width="140"
                  Classes="print-input">
          <ComboBox.ItemTemplate>
            <DataTemplate x:DataType="printing:PrintOutputKind">
              <TextBlock Text="{Binding ., Converter={StaticResource PrintEnumDisplayConverter}}" />
            </DataTemplate>
          </ComboBox.ItemTemplate>
        </ComboBox>
        <Button Grid.Column="2"
                Content="Cancel"
                Classes="print-secondary print-footer"
                Command="{Binding CancelCommand}" />
        <Button Grid.Column="3"
                Content="{Binding PrimaryActionText}"
                Classes="print-secondary print-footer"
                Command="{Binding PrintCommand}" />
      </Grid>
    </Border>
  </Grid>
</Window>
