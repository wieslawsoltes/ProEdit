<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ProEdit.Word.Avalonia"
        x:Class="ProEdit.Word.Avalonia.PdfExportDialog"
        x:DataType="local:PdfExportDialogViewModel"
        Width="440"
        Height="320"
        MinWidth="420"
        MinHeight="280"
        WindowStartupLocation="CenterOwner"
        Title="Export PDF">
  <Window.Resources>
    <local:EnumEqualsConverter x:Key="EnumEqualsConverter" />
  </Window.Resources>

  <StackPanel Margin="20" Spacing="14">
    <StackPanel Spacing="6">
      <TextBlock Text="Export PDF" FontSize="18" FontWeight="SemiBold" />
      <TextBlock Text="Choose how to save this PDF." Foreground="{DynamicResource ThemeForegroundLowBrush}" />
    </StackPanel>

    <Border BorderBrush="{DynamicResource ThemeBorderLowBrush}" BorderThickness="1" CornerRadius="8" Padding="12">
      <StackPanel Spacing="8">
        <TextBlock Text="Output" FontWeight="SemiBold" />
        <RadioButton Content="Regenerate PDF (recommended)"
                     GroupName="ExportMode"
                     IsChecked="{Binding ExportMode, Mode=TwoWay, Converter={StaticResource EnumEqualsConverter}, ConverterParameter=Regenerate}" />
        <TextBlock Text="Rebuild the PDF from the document model."
                   Foreground="{DynamicResource ThemeForegroundLowBrush}" />

        <RadioButton Content="Preserve original PDF"
                     GroupName="ExportMode"
                     IsEnabled="{Binding CanPreserve}"
                     IsChecked="{Binding ExportMode, Mode=TwoWay, Converter={StaticResource EnumEqualsConverter}, ConverterParameter=Preserve}" />
        <TextBlock Text="Keep the original PDF bytes. Changes may be ignored."
                   Foreground="{DynamicResource ThemeForegroundLowBrush}" />

        <TextBlock Text="Original PDF data is not available for this document."
                   Foreground="{DynamicResource ThemeForegroundLowBrush}"
                   IsVisible="{Binding ShowPreserveUnavailable}" />

        <TextBlock Text="Incremental preservation is not available yet. Export will regenerate the PDF."
                   Foreground="{DynamicResource ThemeForegroundLowBrush}"
                   IsVisible="{Binding ShowIncrementalWarning}" />
        <TextBlock Text="{Binding IncrementalDetails}"
                   Foreground="{DynamicResource ThemeForegroundLowBrush}"
                   TextWrapping="Wrap"
                   IsVisible="{Binding ShowIncrementalDetails}" />

        <StackPanel Spacing="4" IsVisible="{Binding ShowChangeWarning}">
          <CheckBox Content="Allow preserve even if the document has changed"
                    IsChecked="{Binding AllowPreserveWithChanges, Mode=TwoWay}" />
          <TextBlock Text="Preserving will ignore your edits and keep the original file."
                     Foreground="{DynamicResource ThemeForegroundLowBrush}"
                     TextWrapping="Wrap" />
        </StackPanel>
      </StackPanel>
    </Border>

    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
      <Button Content="Cancel" Command="{Binding CancelCommand}" />
      <Button Content="Export" Command="{Binding ConfirmCommand}" IsDefault="True" />
    </StackPanel>
  </StackPanel>
</Window>
