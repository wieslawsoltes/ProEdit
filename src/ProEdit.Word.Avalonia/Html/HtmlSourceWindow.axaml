<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ProEdit.Word.Avalonia.HtmlSourceWindow"
        Title="HTML Source"
        Width="720"
        Height="520"
        MinWidth="420"
        MinHeight="300">
  <Grid RowDefinitions="Auto,*">
    <StackPanel Orientation="Horizontal" Margin="8" Spacing="8">
      <Button Name="ApplyButton" Content="Apply" />
      <Button Name="RefreshButton" Content="Refresh" />
      <CheckBox Name="AutoSyncCheckBox" Content="Auto sync" IsChecked="True" />
    </StackPanel>
    <TextBox Name="HtmlEditor"
             Grid.Row="1"
             AcceptsReturn="True"
             TextWrapping="NoWrap"
             ScrollViewer.VerticalScrollBarVisibility="Auto"
             ScrollViewer.HorizontalScrollBarVisibility="Auto"
             FontFamily="Consolas"
             FontSize="13"
             Margin="8" />
  </Grid>
</Window>
