    <Nullable>enable</Nullable>
    <AvaloniaUseCompiledBindingsByDefault>true</AvaloniaUseCompiledBindingsByDefault>
  </PropertyGroup>

  <PropertyGroup>
    <PackageDescription>Avalonia attached collaboration behavior for ProEdit RichTextBox.</PackageDescription>
    <PackageTags>proedit;richtextbox;collaboration;avalonia</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Avalonia" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\ProEdit.Collaboration.Protocol\ProEdit.Collaboration.Protocol.csproj" />
    <ProjectReference Include="..\ProEdit.Collaboration.UI\ProEdit.Collaboration.UI.csproj" />
    <ProjectReference Include="..\ProEdit.RichText.Avalonia\ProEdit.RichText.Avalonia.csproj" />
  </ItemGroup>
</Project>
