<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Style Selector="Border.viewer-toolbar">
    <Setter Property="Padding" Value="10" />
    <Setter Property="Background" Value="#F9FBFD" />
    <Setter Property="BorderBrush" Value="#D6E0EB" />
    <Setter Property="BorderThickness" Value="0,0,0,1" />
  </Style>

  <Style Selector="Button.viewer-tool-button">
    <Setter Property="Padding" Value="12,8" />
    <Setter Property="MinHeight" Value="34" />
  </Style>

  <Style Selector="Button.viewer-tool-button-primary">
    <Setter Property="Background" Value="#115EA3" />
    <Setter Property="Foreground" Value="White" />
    <Setter Property="BorderBrush" Value="#0F548C" />
  </Style>

  <Style Selector="Button.viewer-list-button">
    <Setter Property="Padding" Value="8,6" />
  </Style>

  <Style Selector="Border.viewer-status-pill">
    <Setter Property="Padding" Value="10,6" />
    <Setter Property="CornerRadius" Value="999" />
    <Setter Property="Background" Value="#EEF3F9" />
    <Setter Property="BorderBrush" Value="#D6E0EB" />
    <Setter Property="BorderThickness" Value="1" />
  </Style>

  <Style Selector="Border.viewer-sidebar">
    <Setter Property="Padding" Value="12" />
    <Setter Property="Background" Value="#FBFCFE" />
    <Setter Property="BorderBrush" Value="#D6E0EB" />
    <Setter Property="BorderThickness" Value="0,0,1,0" />
  </Style>

  <Style Selector="GridSplitter.viewer-splitter">
    <Setter Property="Width" Value="6" />
    <Setter Property="Background" Value="#00000000" />
  </Style>

  <Style Selector="GridSplitter.viewer-splitter:pointerover">
    <Setter Property="Background" Value="#D9E6F4" />
  </Style>

  <Style Selector="Border.viewer-preview">
    <Setter Property="Padding" Value="14" />
    <Setter Property="Background" Value="#F3F6FA" />
  </Style>

  <Style Selector="Border.viewer-card">
    <Setter Property="Padding" Value="10" />
    <Setter Property="Margin" Value="0,0,0,8" />
    <Setter Property="CornerRadius" Value="10" />
    <Setter Property="Background" Value="#FFFFFF" />
    <Setter Property="BorderBrush" Value="#D6E0EB" />
    <Setter Property="BorderThickness" Value="1" />
  </Style>

  <Style Selector="TextBlock.viewer-label">
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="#172B45" />
  </Style>

  <Style Selector="TextBlock.viewer-helper">
    <Setter Property="FontSize" Value="11" />
    <Setter Property="Foreground" Value="#61758D" />
  </Style>

  <Style Selector="Border.viewer-page-shell">
    <Setter Property="Padding" Value="18" />
    <Setter Property="Background" Value="#FFFFFF" />
    <Setter Property="CornerRadius" Value="12" />
    <Setter Property="BorderBrush" Value="#CCD9E6" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="BoxShadow" Value="0 16 34 0 #180F172A" />
  </Style>

  <Style Selector="ListBox.viewer-thumbnails">
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="Padding" Value="0" />
  </Style>

  <Style Selector="Border.viewer-thumbnail">
    <Setter Property="Padding" Value="10" />
    <Setter Property="Margin" Value="0,0,10,0" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Background" Value="#FFFFFF" />
    <Setter Property="BorderBrush" Value="#D6E0EB" />
    <Setter Property="BorderThickness" Value="1" />
  </Style>

  <Style Selector="TabControl.viewer-pane-tabs TabItem">
    <Setter Property="Padding" Value="10,8" />
  </Style>
</Styles>
