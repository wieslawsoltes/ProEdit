<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <AvaloniaUseCompiledBindingsByDefault>true</AvaloniaUseCompiledBindingsByDefault>
  </PropertyGroup>
  <PropertyGroup Condition="'$(IsDocFxBuild)' == 'true'">
    <EmitCompilerGeneratedFiles>true</EmitCompilerGeneratedFiles>
    <CompilerGeneratedFilesOutputPath>Generated</CompilerGeneratedFilesOutputPath>
  </PropertyGroup>
  <ItemGroup Condition="'$(IsDocFxBuild)' == 'true'">
    <Compile Remove="Generated\\**\\*.cs" />
  </ItemGroup>
  <ItemGroup Condition="'$(IsDocFxMetadata)' == 'true'">
    <Compile Remove="Generated\\Avalonia.Generators\\**\\*.cs" />
  </ItemGroup>
  <PropertyGroup>
    <PackageDescription>Avalonia viewer surfaces for VibeOffice reporting.</PackageDescription>
    <PackageTags>vibeoffice;reporting;avalonia;viewer;preview</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Avalonia" />
    <PackageReference Include="Avalonia.Skia" />
    <PackageReference Include="Avalonia.Themes.Fluent" />
    <PackageReference Include="ReactiveUI" />
    <PackageReference Include="ReactiveUI.Avalonia" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\\Vibe.Office.Reporting.Core\\Vibe.Office.Reporting.Core.csproj" />
    <ProjectReference Include="..\\Vibe.Office.Reporting.Data\\Vibe.Office.Reporting.Data.csproj" />
    <ProjectReference Include="..\\Vibe.Office.Reporting.DocumentComposition\\Vibe.Office.Reporting.DocumentComposition.csproj" />
    <ProjectReference Include="..\\Vibe.Office.Reporting.Export\\Vibe.Office.Reporting.Export.csproj" />
    <ProjectReference Include="..\\Vibe.Office.Reporting.Expressions\\Vibe.Office.Reporting.Expressions.csproj" />
    <ProjectReference Include="..\\Vibe.Office.Reporting.Materialization\\Vibe.Office.Reporting.Materialization.csproj" />
    <ProjectReference Include="..\\Vibe.Office.Documents\\Vibe.Office.Documents.csproj" />
    <ProjectReference Include="..\\Vibe.Office.Layout\\Vibe.Office.Layout.csproj" />
    <ProjectReference Include="..\\Vibe.Office.Printing\\Vibe.Office.Printing.csproj" />
    <ProjectReference Include="..\\Vibe.Office.Printing.Documents\\Vibe.Office.Printing.Documents.csproj" />
    <ProjectReference Include="..\\Vibe.Office.Printing.Skia\\Vibe.Office.Printing.Skia.csproj" />
    <ProjectReference Include="..\\Vibe.Office.Printing.System\\Vibe.Office.Printing.System.csproj" />
    <ProjectReference Include="..\\Vibe.Office.Rendering\\Vibe.Office.Rendering.csproj" />
    <ProjectReference Include="..\\Vibe.Office.Rendering.Skia\\Vibe.Office.Rendering.Skia.csproj" />
  </ItemGroup>
</Project>
