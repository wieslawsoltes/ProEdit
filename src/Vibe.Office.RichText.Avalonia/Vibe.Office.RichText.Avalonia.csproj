<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <AvaloniaUseCompiledBindingsByDefault>true</AvaloniaUseCompiledBindingsByDefault>
  </PropertyGroup>

  <PropertyGroup>
    <PackageDescription>Avalonia RichTextBox control for FlowDocument editing on VibeOffice infrastructure.</PackageDescription>
    <PackageTags>vibeoffice;richtextbox;flowdocument;avalonia</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Avalonia" />
  </ItemGroup>

  <ItemGroup>
    <AvaloniaXaml Include="Themes\Generic.axaml" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Vibe.Office.Documents\Vibe.Office.Documents.csproj" />
    <ProjectReference Include="..\Vibe.Office.Editing\Vibe.Office.Editing.csproj" />
    <ProjectReference Include="..\Vibe.Office.FlowDocument\Vibe.Office.FlowDocument.csproj" />
    <ProjectReference Include="..\Vibe.Office.FlowDocument.Documents\Vibe.Office.FlowDocument.Documents.csproj" />
    <ProjectReference Include="..\Vibe.Word.Avalonia\Vibe.Word.Avalonia.csproj" />
  </ItemGroup>
</Project>
