<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ribbon="clr-namespace:Vibe.Office.Ribbon;assembly=Vibe.Office.Ribbon"
        xmlns:local="clr-namespace:Vibe.Office.Ribbon.Avalonia;assembly=Vibe.Office.Ribbon.Avalonia">
  <Styles.Resources>
    <ResourceDictionary>
      <local:RibbonStringNotEmptyConverter x:Key="RibbonStringNotEmptyConverter" />

      <Color x:Key="RibbonSurfaceColor">#F3F4F7</Color>
      <SolidColorBrush x:Key="RibbonSurfaceBrush" Color="{StaticResource RibbonSurfaceColor}" />

      <Color x:Key="RibbonTabStripColor">#F7F8FA</Color>
      <Color x:Key="RibbonContentColor">#FFFFFF</Color>
      <Color x:Key="RibbonBorderColor">#DADFE6</Color>
      <Color x:Key="RibbonTabStripBorderColor">#E1E4EA</Color>
      <Color x:Key="RibbonAccentColor">#0078D4</Color>
      <Color x:Key="RibbonGroupColor">#FFFFFF</Color>
      <Color x:Key="RibbonGroupBorderColor">#E1E5EC</Color>

      <Color x:Key="RibbonTopBarColor">#F7F8FA</Color>
      <SolidColorBrush x:Key="RibbonTopBarBrush" Color="{StaticResource RibbonTopBarColor}" />
      <SolidColorBrush x:Key="RibbonTopBarBorderBrush" Color="#E2E6ED" />
      <Thickness x:Key="RibbonTopBarPadding">8,6</Thickness>
      <x:Double x:Key="RibbonTopBarMinHeight">36</x:Double>
      <SolidColorBrush x:Key="RibbonTopBarTitleBrush" Color="#1A1A1A" />
      <SolidColorBrush x:Key="RibbonTopBarAppNameBrush" Color="#6A6A6A" />
      <SolidColorBrush x:Key="RibbonTopBarStatusBrush" Color="#3A3A3A" />
      <SolidColorBrush x:Key="RibbonTopBarBadgeBrush" Color="#0078D4" />
      <SolidColorBrush x:Key="RibbonTopBarBadgeForegroundBrush" Color="#FFFFFF" />
      <SolidColorBrush x:Key="RibbonTopBarPillBorderBrush" Color="#D6DAE2" />
      <SolidColorBrush x:Key="RibbonTopBarPillBackgroundBrush" Color="#FFFFFF" />
      <SolidColorBrush x:Key="RibbonTopBarProfileBrush" Color="#E7EAF0" />
      <SolidColorBrush x:Key="RibbonTopBarProfileForegroundBrush" Color="#2B2B2B" />
      <x:Double x:Key="RibbonTopBarTitleFontSize">13</x:Double>
      <x:Double x:Key="RibbonTopBarAppNameFontSize">10</x:Double>
      <x:Double x:Key="RibbonTopBarStatusFontSize">11</x:Double>
      <x:Double x:Key="RibbonTopBarProfileFontSize">11</x:Double>
      <CornerRadius x:Key="RibbonTopBarBadgeCornerRadius">6</CornerRadius>
      <CornerRadius x:Key="RibbonTopBarPillCornerRadius">10</CornerRadius>

      <SolidColorBrush x:Key="RibbonTabStripBrush" Color="{StaticResource RibbonTabStripColor}" />
      <SolidColorBrush x:Key="RibbonContentBrush" Color="{StaticResource RibbonContentColor}" />
      <SolidColorBrush x:Key="RibbonBorderBrush" Color="{StaticResource RibbonBorderColor}" />
      <SolidColorBrush x:Key="RibbonTabStripBorderBrush" Color="{StaticResource RibbonTabStripBorderColor}" />
      <SolidColorBrush x:Key="RibbonAccentBrush" Color="{StaticResource RibbonAccentColor}" />
      <SolidColorBrush x:Key="RibbonGroupBrush" Color="{StaticResource RibbonGroupColor}" />
      <SolidColorBrush x:Key="RibbonGroupBorderBrush" Color="{StaticResource RibbonGroupBorderColor}" />
      <SolidColorBrush x:Key="RibbonTabForegroundBrush" Color="#404040" />
      <SolidColorBrush x:Key="RibbonTabForegroundSelectedBrush" Color="#1A1A1A" />
      <SolidColorBrush x:Key="RibbonTabForegroundDisabledBrush" Color="#9A9A9A" />

      <SolidColorBrush x:Key="RibbonButtonBackgroundBrush" Color="Transparent" />
      <SolidColorBrush x:Key="RibbonButtonBorderBrush" Color="Transparent" />
      <SolidColorBrush x:Key="RibbonButtonForegroundBrush" Color="#2B2B2B" />
      <SolidColorBrush x:Key="RibbonButtonBackgroundPointerOverBrush" Color="#EAF2FF" />
      <SolidColorBrush x:Key="RibbonButtonBorderPointerOverBrush" Color="#A8C6F0" />
