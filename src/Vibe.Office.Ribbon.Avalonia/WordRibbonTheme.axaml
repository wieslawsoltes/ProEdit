      <Thickness x:Key="RibbonComboBorderPadding">1</Thickness>
      <x:Double x:Key="RibbonComboFontSize">12</x:Double>

      <CornerRadius x:Key="RibbonTextBoxCornerRadius">6</CornerRadius>
      <Thickness x:Key="RibbonTextBoxPadding">8,2</Thickness>
      <x:Double x:Key="RibbonTextBoxMinWidth">260</x:Double>
      <x:Double x:Key="RibbonTextBoxMinHeight">28</x:Double>
      <x:Double x:Key="RibbonTextBoxFontSize">12</x:Double>

      <CornerRadius x:Key="RibbonSpinnerCornerRadius">3</CornerRadius>
      <Thickness x:Key="RibbonSpinnerTextPadding">6,2</Thickness>
      <x:Double x:Key="RibbonSpinnerArrowWidth">16</x:Double>
      <x:Double x:Key="RibbonSpinnerArrowFontSize">10</x:Double>
      <x:Double x:Key="RibbonSpinnerArrowMinHeight">10</x:Double>

      <SolidColorBrush x:Key="RibbonToolTipBackgroundBrush" Color="#FFFFFF" />
      <SolidColorBrush x:Key="RibbonToolTipBorderBrush" Color="#D0D4DB" />
      <SolidColorBrush x:Key="RibbonToolTipTitleForegroundBrush" Color="#1B1B1B" />
      <SolidColorBrush x:Key="RibbonToolTipBodyForegroundBrush" Color="#3A3A3A" />
      <SolidColorBrush x:Key="RibbonToolTipShortcutForegroundBrush" Color="#5A5A5A" />
      <Thickness x:Key="RibbonToolTipPadding">8,6</Thickness>
      <CornerRadius x:Key="RibbonToolTipCornerRadius">4</CornerRadius>
      <x:Double x:Key="RibbonToolTipTitleFontSize">12</x:Double>
      <x:Double x:Key="RibbonToolTipBodyFontSize">11</x:Double>
      <x:Double x:Key="RibbonToolTipShortcutFontSize">10</x:Double>
      <x:Double x:Key="RibbonToolTipMaxWidth">280</x:Double>

      <SolidColorBrush x:Key="RibbonKeyTipBackgroundBrush" Color="#FFF4CE" />
      <SolidColorBrush x:Key="RibbonKeyTipBorderBrush" Color="#D3A400" />
      <SolidColorBrush x:Key="RibbonKeyTipForegroundBrush" Color="#1B1B1B" />
