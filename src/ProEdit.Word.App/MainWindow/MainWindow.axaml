<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:word="clr-namespace:ProEdit.Word.Avalonia;assembly=ProEdit.Word.Avalonia"
        mc:Ignorable="d" d:DesignWidth="1024" d:DesignHeight="768"
        x:Class="ProEdit.Word.App.MainWindow"
        Background="{DynamicResource RibbonSurfaceBrush}"
        Title="ProEdit Word">
    <word:WordEditorControl x:Name="EditorControl" />
</Window>
