<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Vibe.Word.Avalonia.ThesaurusWindow"
        Title="Thesaurus"
        Width="520"
        Height="360"
        MinWidth="420"
        MinHeight="300">
  <Grid RowDefinitions="Auto,*,Auto" Margin="12" RowSpacing="8" ColumnSpacing="12">
    <StackPanel Orientation="Horizontal" Spacing="8">
      <TextBlock Text="Look up:" VerticalAlignment="Center" />
      <TextBox x:Name="LookupBox" Width="220" />
      <Button x:Name="LookupButton" Content="Search" />
    </StackPanel>

    <Grid Grid.Row="1" ColumnDefinitions="*,160" ColumnSpacing="12">
      <ListBox x:Name="SynonymsList" />
      <StackPanel Grid.Column="1" Spacing="8">
        <Button x:Name="ReplaceButton" Content="Replace" />
        <Button x:Name="ReplaceAllButton" Content="Replace All" />
      </StackPanel>
    </Grid>

    <TextBlock x:Name="StatusText"
               Grid.Row="2"
               Foreground="#606060"
               Text="No thesaurus provider configured." />
  </Grid>
</Window>
