<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Vibe.Word.Avalonia"
        xmlns:sys="clr-namespace:System;assembly=System.Runtime"
        x:Class="Vibe.Word.Avalonia.PdfImportDialog"
        x:DataType="local:PdfImportDialogViewModel"
        Width="440"
        Height="520"
        MinWidth="420"
        MinHeight="360"
        MaxHeight="720"
        SizeToContent="Width"
        WindowStartupLocation="CenterOwner"
        Title="Import PDF">
  <Window.Resources>
    <local:PdfEnumDisplayConverter x:Key="PdfEnumDisplayConverter" />
    <local:EnumEqualsConverter x:Key="EnumEqualsConverter" />
  </Window.Resources>

  <Grid RowDefinitions="*,Auto"
        Margin="20">
    <ScrollViewer Grid.Row="0"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
      <StackPanel Spacing="14">
        <StackPanel Spacing="6">
          <TextBlock Text="Import PDF" FontSize="18" FontWeight="SemiBold" />
          <TextBlock Text="Choose how to import this PDF into the document model." Foreground="{DynamicResource ThemeForegroundLowBrush}" />
        </StackPanel>

        <Border BorderBrush="{DynamicResource ThemeBorderLowBrush}" BorderThickness="1" CornerRadius="8" Padding="12">
          <StackPanel Spacing="8">
            <TextBlock Text="Layout" FontWeight="SemiBold" />
            <RadioButton Content="Reflow (editable)"
                         GroupName="ImportMode"
                         IsChecked="{Binding ImportMode, Mode=TwoWay, Converter={StaticResource EnumEqualsConverter}, ConverterParameter=Reflow}" />
            <RadioButton Content="Fixed layout (preserve geometry)"
                         GroupName="ImportMode"
                         IsChecked="{Binding ImportMode, Mode=TwoWay, Converter={StaticResource EnumEqualsConverter}, ConverterParameter=FixedLayout}" />
          </StackPanel>
        </Border>

        <Border BorderBrush="{DynamicResource ThemeBorderLowBrush}" BorderThickness="1" CornerRadius="8" Padding="12">
          <StackPanel Spacing="8">
            <TextBlock Text="Preservation" FontWeight="SemiBold" />
            <ComboBox ItemsSource="{Binding PreservationOptions}"
                      SelectedItem="{Binding PreservationMode, Mode=TwoWay}">
              <ComboBox.ItemTemplate>
                <DataTemplate x:DataType="sys:Enum">
                  <TextBlock Text="{Binding ., Converter={StaticResource PdfEnumDisplayConverter}}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
            <TextBlock Text="Preserve original PDF data for optional incremental updates." Foreground="{DynamicResource ThemeForegroundLowBrush}" />
          </StackPanel>
        </Border>
      </StackPanel>
    </ScrollViewer>

    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,12,0,0">
      <Button Content="Cancel" Command="{Binding CancelCommand}" />
      <Button Content="Import" Command="{Binding ConfirmCommand}" IsDefault="True" />
    </StackPanel>
  </Grid>
</Window>
