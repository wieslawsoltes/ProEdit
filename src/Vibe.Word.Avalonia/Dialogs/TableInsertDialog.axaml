<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:primitives="clr-namespace:Avalonia.Controls.Primitives;assembly=Avalonia.Controls"
        x:Class="Vibe.Word.Avalonia.TableInsertDialog"
        Width="360"
        Height="300"
        WindowStartupLocation="CenterOwner"
        Title="Insert Table">
  <Grid RowDefinitions="Auto,*,Auto"
        RowSpacing="10"
        Margin="12">
    <TextBlock x:Name="SelectionText"
               FontSize="13"
               FontWeight="SemiBold"
               Text="Insert Table: 1 x 1" />
    <Border Grid.Row="1"
            BorderBrush="#D0D4DB"
            BorderThickness="1"
            CornerRadius="4"
            Padding="8">
      <primitives:UniformGrid x:Name="GridHost"
                              Rows="8"
                              Columns="10" />
    </Border>
    <StackPanel Grid.Row="2"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Spacing="8">
      <Button Content="Insert"
              Width="80"
              Click="OnInsertClick" />
      <Button Content="Cancel"
              Width="80"
              Click="OnCancelClick" />
    </StackPanel>
  </Grid>
</Window>
