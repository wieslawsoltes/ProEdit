<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <AvaloniaUseCompiledBindingsByDefault>true</AvaloniaUseCompiledBindingsByDefault>
  </PropertyGroup>
  <PropertyGroup Condition="'$(IsDocFxBuild)' == 'true'">
    <EmitCompilerGeneratedFiles>true</EmitCompilerGeneratedFiles>
    <CompilerGeneratedFilesOutputPath>Generated</CompilerGeneratedFilesOutputPath>
  </PropertyGroup>
  <ItemGroup Condition="'$(IsDocFxBuild)' == 'true'">
    <Compile Remove="Generated\\**\\*.cs" />
  </ItemGroup>
  <ItemGroup Condition="'$(IsDocFxMetadata)' == 'true'">
    <Compile Remove="Generated\\Avalonia.Generators\\**\\*.cs" />
  </ItemGroup>
  <PropertyGroup>
    <PackageDescription>Avalonia UI for the VibeWord editor.</PackageDescription>
    <PackageTags>vibeoffice;avalonia;editor;word</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Avalonia" />
    <PackageReference Include="Avalonia.Skia" />
    <PackageReference Include="Avalonia.Themes.Fluent" />
    <PackageReference Include="Avalonia.Fonts.Inter" />
    <PackageReference Include="ReactiveUI" />
    <PackageReference Include="ReactiveUI.Avalonia" />
    <PackageReference Include="ReactiveUI.SourceGenerators">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\\Vibe.Office.Rendering\\Vibe.Office.Rendering.csproj" />
    <ProjectReference Include="..\\Vibe.Office.Rendering.Skia\\Vibe.Office.Rendering.Skia.csproj" />
    <ProjectReference Include="..\\Vibe.Office.Ribbon.Avalonia\\Vibe.Office.Ribbon.Avalonia.csproj" />
    <ProjectReference Include="..\\Vibe.Office.Collaboration.Editor\\Vibe.Office.Collaboration.Editor.csproj" />
    <ProjectReference Include="..\\Vibe.Office.Collaboration.UI\\Vibe.Office.Collaboration.UI.csproj" />
    <ProjectReference Include="..\\Vibe.Office.Editing\\Vibe.Office.Editing.csproj" />
    <ProjectReference Include="..\\Vibe.Office.Html\\Vibe.Office.Html.csproj" />
    <ProjectReference Include="..\\Vibe.Office.Markdown\\Vibe.Office.Markdown.csproj" />
    <ProjectReference Include="..\\Vibe.Office.Macros\\Vibe.Office.Macros.csproj" />
    <ProjectReference Include="..\\Vibe.Office.Pdf\\Vibe.Office.Pdf.csproj" />
    <ProjectReference Include="..\\Vibe.Office.Pdf.Documents\\Vibe.Office.Pdf.Documents.csproj" />
    <ProjectReference Include="..\\Vibe.Office.Pdf.PdfPig\\Vibe.Office.Pdf.PdfPig.csproj" />
    <ProjectReference Include="..\\Vibe.Office.Pdf.PdfSharp\\Vibe.Office.Pdf.PdfSharp.csproj" />
    <ProjectReference Include="..\\Vibe.Office.Printing.Avalonia\\Vibe.Office.Printing.Avalonia.csproj" />
    <ProjectReference Include="..\\Vibe.Office.Printing.Documents\\Vibe.Office.Printing.Documents.csproj" />
    <ProjectReference Include="..\\Vibe.Office.Printing.Skia\\Vibe.Office.Printing.Skia.csproj" />
    <ProjectReference Include="..\\Vibe.Office.Printing.System\\Vibe.Office.Printing.System.csproj" />
    <ProjectReference Include="..\\Vibe.Word.Editor\\Vibe.Word.Editor.csproj" />
    <ProjectReference Include="..\\Vibe.Office.OpenXml\\Vibe.Office.OpenXml.csproj" />
  </ItemGroup>
</Project>
