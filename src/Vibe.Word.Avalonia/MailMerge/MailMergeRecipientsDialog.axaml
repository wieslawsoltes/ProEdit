<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Vibe.Word.Avalonia.MailMergeRecipientsDialog"
        Width="760"
        Height="480"
        WindowStartupLocation="CenterOwner"
        Title="Mail Merge Recipients">
  <Grid RowDefinitions="Auto,*,Auto"
        ColumnDefinitions="220,*"
        RowSpacing="10"
        ColumnSpacing="12"
        Margin="12">
    <StackPanel Grid.Row="0"
                Grid.ColumnSpan="2"
                Orientation="Horizontal"
                Spacing="8">
      <Button Content="Load CSV"
              Click="OnLoadCsvClick" />
      <Button Content="Add Record"
              Click="OnAddRecordClick" />
      <Button Content="Remove Record"
              Click="OnRemoveRecordClick" />
      <TextBox x:Name="NewFieldNameBox"
               Width="140"
               Watermark="New field name" />
      <Button Content="Add Field"
              Click="OnAddFieldClick" />
      <ComboBox x:Name="RemoveFieldCombo"
                Width="140" />
      <Button Content="Remove Field"
              Click="OnRemoveFieldClick" />
    </StackPanel>

    <Border Grid.Row="1"
            Grid.Column="0"
            BorderBrush="#D0D4DB"
            BorderThickness="1"
            CornerRadius="4"
            Padding="4">
      <ListBox x:Name="RecordsList"
               x:CompileBindings="False"
               DisplayMemberBinding="{Binding DisplayName}"
               SelectionMode="Single" />
    </Border>

    <Border Grid.Row="1"
            Grid.Column="1"
            BorderBrush="#D0D4DB"
            BorderThickness="1"
            CornerRadius="4"
            Padding="8">
      <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto">
        <StackPanel x:Name="FieldsPanel"
                    Spacing="6" />
      </ScrollViewer>
    </Border>

    <StackPanel Grid.Row="2"
                Grid.ColumnSpan="2"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Spacing="8">
      <Button Content="OK"
              Width="80"
              Click="OnOkClick" />
      <Button Content="Cancel"
              Width="80"
              Click="OnCancelClick" />
    </StackPanel>
  </Grid>
</Window>
