<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:editing="clr-namespace:Vibe.Office.Editing;assembly=Vibe.Office.Editing"
        x:Class="Vibe.Word.Avalonia.StylesPaneWindow"
        Width="360"
        Height="520"
        MinWidth="300"
        MinHeight="360"
        Title="Styles">
  <Grid Margin="12"
        RowDefinitions="Auto,Auto,*,Auto,Auto">
    <StackPanel Grid.Row="0"
                Spacing="6"
                Margin="0,0,0,8">
      <TextBlock x:Name="PaneTitle"
                 Text="Styles"
                 FontSize="14"
                 FontWeight="SemiBold" />
    </StackPanel>

    <StackPanel Grid.Row="1"
                Spacing="6"
                Margin="0,0,0,8">
      <TextBox x:Name="StyleSearchBox"
               Watermark="Search styles" />
      <DockPanel>
        <ComboBox x:Name="StyleFilterCombo"
                  Width="150">
          <ComboBoxItem Content="All Styles" />
          <ComboBoxItem Content="In Use" />
          <ComboBoxItem Content="Quick Styles" />
          <ComboBoxItem Content="Recommended" />
        </ComboBox>
        <ComboBox x:Name="StyleTypeCombo"
                  DockPanel.Dock="Right"
                  Width="150"
                  Margin="8,0,0,0">
          <ComboBoxItem Content="All Types" />
          <ComboBoxItem Content="Paragraph" />
          <ComboBoxItem Content="Character" />
          <ComboBoxItem Content="Table" />
        </ComboBox>
      </DockPanel>
    </StackPanel>

    <ListBox x:Name="StylesList"
             Grid.Row="2"
             MinHeight="180">
      <ListBox.ItemTemplate>
        <DataTemplate x:DataType="editing:EditorStyleInfo">
          <StackPanel Spacing="2">
            <TextBlock Text="{Binding Name}" />
            <TextBlock Text="{Binding Type}"
                       FontSize="11"
                       Foreground="#666666" />
          </StackPanel>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>

    <Border x:Name="StylePreviewPanel"
            Grid.Row="3"
            BorderBrush="#DDDDDD"
            BorderThickness="1"
            Padding="8"
            Margin="0,8,0,0">
      <StackPanel Spacing="4">
        <TextBlock x:Name="StylePreviewText"
                   Text="AaBbCcDd"
                   FontSize="16" />
        <TextBlock x:Name="StyleDetailsText" />
        <TextBlock x:Name="StyleDirectFormattingText" />
      </StackPanel>
    </Border>

    <StackPanel Grid.Row="4"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Margin="0,8,0,0"
                Spacing="6">
      <Button x:Name="NewStyleButton"
              Content="New Style" />
      <Button x:Name="InspectorButton"
              Content="Style Inspector" />
      <Button x:Name="ManageButton"
              Content="Manage Styles" />
      <Button x:Name="OrganizerButton"
              Content="Organizer" />
      <Button x:Name="OptionsButton"
              Content="Options" />
      <Button x:Name="ApplyButton"
              Content="Apply" />
      <Button x:Name="CloseButton"
              Content="Close" />
    </StackPanel>
  </Grid>
</Window>
