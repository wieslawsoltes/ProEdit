<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ProEdit.Reporting.App.ViewModels"
             xmlns:data="clr-namespace:ProEdit.Reporting.Data;assembly=ProEdit.Reporting.Data"
             xmlns:reporting="clr-namespace:ProEdit.Reporting;assembly=ProEdit.Reporting.Core"
             x:Class="ProEdit.Reporting.App.Controls.ReportingStudioSidebar"
             x:DataType="vm:ReportingStudioViewModel">
  <Border Classes="studio-sidebar">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
      <StackPanel Spacing="12">
        <Border Classes="studio-card">
          <StackPanel Spacing="8">
            <TextBlock Classes="studio-section-title"
                       Text="Workspace" />
            <TextBlock Classes="studio-overline"
                       Text="{Binding ActiveDocumentMode}" />
            <TextBlock Classes="studio-emphasis"
                       Text="{Binding WorkspaceSummaryText}"
                       TextWrapping="Wrap" />
            <TextBlock Classes="studio-helper"
                       Text="{Binding CurrentPathDisplay}"
                       TextWrapping="Wrap" />
          </StackPanel>
        </Border>

        <Expander Classes="studio-expander"
                  IsExpanded="True">
          <Expander.Header>
            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="8">
              <TextBlock Classes="studio-section-title"
                         Text="Runtime Status" />
              <Border Classes="studio-chip">
                <TextBlock Text="{Binding PreviewStateText}" />
              </Border>
            </Grid>
          </Expander.Header>
          <StackPanel Spacing="10">
            <Border Classes="studio-card">
              <StackPanel Spacing="4">
                <TextBlock Classes="studio-card-title"
                           Text="Studio" />
                <TextBlock Text="{Binding StatusMessage}"
                           TextWrapping="Wrap" />
              </StackPanel>
            </Border>
            <Border Classes="studio-card">
              <StackPanel Spacing="4">
                <TextBlock Classes="studio-card-title"
                           Text="Designer" />
                <TextBlock Text="{Binding DesignerStatusMessage}"
                           TextWrapping="Wrap" />
              </StackPanel>
            </Border>
            <Border Classes="studio-card">
              <StackPanel Spacing="4">
                <TextBlock Classes="studio-card-title"
                           Text="Viewer" />
                <TextBlock Text="{Binding ViewerStatusMessage}"
                           TextWrapping="Wrap" />
              </StackPanel>
            </Border>
          </StackPanel>
        </Expander>

        <Expander Classes="studio-expander"
                  IsExpanded="True">
          <Expander.Header>
            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="8">
              <TextBlock Classes="studio-section-title"
                         Text="Diagnostics" />
              <Border Classes="studio-chip">
                <TextBlock Text="{Binding DiagnosticsSummaryText}" />
              </Border>
            </Grid>
          </Expander.Header>
          <ItemsControl ItemsSource="{Binding Diagnostics}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="reporting:ReportDiagnostic">
                <Border Classes="studio-diagnostic">
                  <StackPanel Spacing="2">
                    <TextBlock FontWeight="SemiBold"
                               Text="{Binding Severity}" />
                    <TextBlock Text="{Binding Code}" />
                    <TextBlock Text="{Binding Message}"
                               TextWrapping="Wrap" />
                    <TextBlock Classes="studio-helper"
                               Text="{Binding Path}" />
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </Expander>

        <Expander Classes="studio-expander">
          <Expander.Header>
            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="8">
              <TextBlock Classes="studio-section-title"
                         Text="Connectors" />
              <Border Classes="studio-chip">
                <TextBlock Text="{Binding ConnectorsSummaryText}" />
              </Border>
            </Grid>
          </Expander.Header>
          <ItemsControl ItemsSource="{Binding Connectors}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="data:ReportDataConnectorDefinition">
                <Border Classes="studio-card">
                  <StackPanel Spacing="6">
                    <StackPanel Orientation="Horizontal"
                                Spacing="8">
                      <Border Classes="studio-tag">
                        <TextBlock Text="{Binding Category}" />
                      </Border>
                      <TextBlock FontWeight="SemiBold"
                                 Text="{Binding DisplayName}" />
                    </StackPanel>
                    <TextBlock Classes="studio-helper"
                               Text="{Binding Description}"
                               TextWrapping="Wrap" />
                    <TextBlock Classes="studio-caption"
                               Text="{Binding ProviderId}" />
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </Expander>

        <Expander Classes="studio-expander">
          <Expander.Header>
            <TextBlock Classes="studio-section-title"
                       Text="Notes" />
          </Expander.Header>
          <StackPanel Spacing="10">
            <Border Classes="studio-card">
              <StackPanel Spacing="4">
                <TextBlock Classes="studio-card-title"
                           Text="Supported Files" />
                <TextBlock Classes="studio-helper"
                           Text="Native templates save as .vreport.json. RDL imports from .rdl, .rdlx, or .xml and exports back to .rdl."
                           TextWrapping="Wrap" />
              </StackPanel>
            </Border>
            <Border Classes="studio-card">
              <StackPanel Spacing="4">
                <TextBlock Classes="studio-card-title"
                           Text="Referenced Reports" />
                <TextBlock Classes="studio-helper"
                           Text="Sibling native templates are preferred for drillthrough and subreport targets, then .rdl and .rdlx."
                           TextWrapping="Wrap" />
              </StackPanel>
            </Border>
            <Border Classes="studio-card">
              <StackPanel Spacing="4">
                <TextBlock Classes="studio-card-title"
                           Text="Shared Runtime" />
                <TextBlock Classes="studio-helper"
                           Text="Designer preview and dedicated viewer workflows use the same execution, pagination, export, and connector stack."
                           TextWrapping="Wrap" />
              </StackPanel>
            </Border>
          </StackPanel>
        </Expander>
      </StackPanel>
    </ScrollViewer>
  </Border>
</UserControl>
