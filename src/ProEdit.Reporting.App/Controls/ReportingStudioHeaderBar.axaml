<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ProEdit.Reporting.App.ViewModels"
             x:Class="ProEdit.Reporting.App.Controls.ReportingStudioHeaderBar"
             x:DataType="vm:ReportingStudioViewModel">
  <Border Classes="studio-title-strip">
    <Grid ColumnDefinitions="*,Auto"
          ColumnSpacing="12">
      <StackPanel Spacing="2">
        <StackPanel Orientation="Horizontal"
                    Spacing="10">
          <TextBlock Classes="studio-app-title"
                     Text="ProEdit Reporting" />
          <Border Classes="studio-chip studio-chip-accent">
            <TextBlock Classes="studio-caption"
                       Text="{Binding ActiveDocumentMode}" />
          </Border>
        </StackPanel>
        <TextBlock Classes="studio-document-title"
                   Text="{Binding DesignerViewModel.ReportDefinition.Name}" />
        <TextBlock Classes="studio-path-text"
                   Text="{Binding CurrentPathDisplay}"
                   TextWrapping="NoWrap"
                   TextTrimming="CharacterEllipsis" />
      </StackPanel>

      <StackPanel Grid.Column="1"
                  Orientation="Horizontal"
                  VerticalAlignment="Center"
                  Spacing="8">
        <Border Classes="studio-chip">
          <TextBlock Classes="studio-caption"
                     Text="{Binding PreviewStateText}" />
        </Border>
      </StackPanel>
    </Grid>
  </Border>
</UserControl>
