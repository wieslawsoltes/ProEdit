<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <AvaloniaUseCompiledBindingsByDefault>true</AvaloniaUseCompiledBindingsByDefault>
  </PropertyGroup>

  <PropertyGroup>
    <PackageDescription>Avalonia attached collaboration behavior for Vibe RichTextBox.</PackageDescription>
    <PackageTags>vibeoffice;richtextbox;collaboration;avalonia</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Avalonia" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Vibe.Office.Collaboration.Protocol\Vibe.Office.Collaboration.Protocol.csproj" />
    <ProjectReference Include="..\Vibe.Office.Collaboration.UI\Vibe.Office.Collaboration.UI.csproj" />
    <ProjectReference Include="..\Vibe.Office.RichText.Avalonia\Vibe.Office.RichText.Avalonia.csproj" />
  </ItemGroup>
</Project>
