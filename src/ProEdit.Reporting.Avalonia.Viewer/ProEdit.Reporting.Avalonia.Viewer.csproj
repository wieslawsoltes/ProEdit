<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <AvaloniaUseCompiledBindingsByDefault>true</AvaloniaUseCompiledBindingsByDefault>
  </PropertyGroup>
  <PropertyGroup Condition="'$(IsDocFxBuild)' == 'true'">
    <EmitCompilerGeneratedFiles>true</EmitCompilerGeneratedFiles>
    <CompilerGeneratedFilesOutputPath>Generated</CompilerGeneratedFilesOutputPath>
  </PropertyGroup>
  <ItemGroup Condition="'$(IsDocFxBuild)' == 'true'">
    <Compile Remove="Generated\\**\\*.cs" />
  </ItemGroup>
  <ItemGroup Condition="'$(IsDocFxMetadata)' == 'true'">
    <Compile Remove="Generated\\Avalonia.Generators\\**\\*.cs" />
  </ItemGroup>
  <PropertyGroup>
    <PackageDescription>Avalonia viewer surfaces for ProEdit reporting.</PackageDescription>
    <PackageTags>proedit;reporting;avalonia;viewer;preview</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Avalonia" />
    <PackageReference Include="Avalonia.Skia" />
    <PackageReference Include="Avalonia.Themes.Fluent" />
    <PackageReference Include="ReactiveUI" />
    <PackageReference Include="ReactiveUI.Avalonia" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\\ProEdit.Reporting.Core\\ProEdit.Reporting.Core.csproj" />
    <ProjectReference Include="..\\ProEdit.Reporting.Data\\ProEdit.Reporting.Data.csproj" />
    <ProjectReference Include="..\\ProEdit.Reporting.DocumentComposition\\ProEdit.Reporting.DocumentComposition.csproj" />
    <ProjectReference Include="..\\ProEdit.Reporting.Export\\ProEdit.Reporting.Export.csproj" />
    <ProjectReference Include="..\\ProEdit.Reporting.Expressions\\ProEdit.Reporting.Expressions.csproj" />
    <ProjectReference Include="..\\ProEdit.Reporting.Materialization\\ProEdit.Reporting.Materialization.csproj" />
    <ProjectReference Include="..\\ProEdit.Documents\\ProEdit.Documents.csproj" />
    <ProjectReference Include="..\\ProEdit.Layout\\ProEdit.Layout.csproj" />
    <ProjectReference Include="..\\ProEdit.Printing\\ProEdit.Printing.csproj" />
    <ProjectReference Include="..\\ProEdit.Printing.Documents\\ProEdit.Printing.Documents.csproj" />
    <ProjectReference Include="..\\ProEdit.Printing.Skia\\ProEdit.Printing.Skia.csproj" />
    <ProjectReference Include="..\\ProEdit.Printing.System\\ProEdit.Printing.System.csproj" />
    <ProjectReference Include="..\\ProEdit.Rendering\\ProEdit.Rendering.csproj" />
    <ProjectReference Include="..\\ProEdit.Rendering.Skia\\ProEdit.Rendering.Skia.csproj" />
  </ItemGroup>
</Project>
