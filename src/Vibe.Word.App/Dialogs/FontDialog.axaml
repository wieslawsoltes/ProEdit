<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Vibe.Word.App.FontDialog"
        Width="600"
        Height="520"
        WindowStartupLocation="CenterOwner"
        Title="Font">
  <Grid RowDefinitions="*,Auto"
        Margin="12">
    <TabControl x:Name="Tabs">
      <TabItem Header="Font">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <StackPanel Spacing="12">
            <Border BorderBrush="#D0D0D0"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="8">
              <StackPanel Spacing="8">
                <TextBlock Text="Font"
                           FontWeight="SemiBold" />
                <Grid ColumnDefinitions="*,*,Auto"
                      RowDefinitions="Auto,Auto"
                      ColumnSpacing="8"
                      RowSpacing="6">
                  <TextBlock Text="Font:"
                             VerticalAlignment="Center" />
                  <TextBlock Grid.Column="1"
                             Text="Font style:"
                             VerticalAlignment="Center" />
                  <TextBlock Grid.Column="2"
                             Text="Size:"
                             VerticalAlignment="Center" />

                  <ComboBox x:Name="FontFamilyCombo"
                            Grid.Row="1"
                            Grid.Column="0"
                            MinWidth="200"
                            IsEditable="True"
                            SelectionChanged="OnSelectionChanged" />
                  <ComboBox x:Name="FontStyleCombo"
                            Grid.Row="1"
                            Grid.Column="1"
                            MinWidth="150"
                            SelectionChanged="OnSelectionChanged" />
                  <ComboBox x:Name="FontSizeCombo"
                            Grid.Row="1"
                            Grid.Column="2"
                            Width="90"
                            IsEditable="True"
                            SelectionChanged="OnSelectionChanged" />
                </Grid>
              </StackPanel>
            </Border>

            <Border BorderBrush="#D0D0D0"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="8">
              <StackPanel Spacing="8">
                <TextBlock Text="Underline and color"
                           FontWeight="SemiBold" />
                <Grid ColumnDefinitions="Auto,*"
                      RowDefinitions="Auto,Auto,Auto"
                      ColumnSpacing="8"
                      RowSpacing="6">
                  <TextBlock Text="Underline style:"
                             VerticalAlignment="Center" />
                  <ComboBox x:Name="UnderlineStyleCombo"
                            Grid.Column="1"
                            Width="200"
                            SelectionChanged="OnSelectionChanged" />

                  <TextBlock Grid.Row="1"
                             Text="Underline color:"
                             VerticalAlignment="Center" />
                  <ComboBox x:Name="UnderlineColorCombo"
                            Grid.Row="1"
                            Grid.Column="1"
                            Width="200"
                            SelectionChanged="OnSelectionChanged" />

                  <TextBlock Grid.Row="2"
                             Text="Font color:"
                             VerticalAlignment="Center" />
                  <ComboBox x:Name="FontColorCombo"
                            Grid.Row="2"
                            Grid.Column="1"
                            Width="200"
                            SelectionChanged="OnSelectionChanged" />
                </Grid>
              </StackPanel>
            </Border>

            <Border BorderBrush="#D0D0D0"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="8">
              <StackPanel Spacing="8">
                <TextBlock Text="Effects"
                           FontWeight="SemiBold" />
                <Grid ColumnDefinitions="*,*"
                      RowDefinitions="Auto,Auto,Auto,Auto"
                      ColumnSpacing="12"
                      RowSpacing="6">
                  <CheckBox x:Name="StrikethroughCheckBox"
                            Content="Strikethrough"
                            IsThreeState="True"
                            Grid.Row="0"
                            Grid.Column="0"
                            Checked="OnToggleChanged"
                            Unchecked="OnToggleChanged" />
                  <CheckBox x:Name="SmallCapsCheckBox"
                            Content="Small caps"
                            IsThreeState="True"
                            Grid.Row="0"
                            Grid.Column="1"
                            Checked="OnToggleChanged"
                            Unchecked="OnToggleChanged" />
                  <CheckBox x:Name="AllCapsCheckBox"
                            Content="All caps"
                            IsThreeState="True"
                            Grid.Row="1"
                            Grid.Column="0"
                            Checked="OnToggleChanged"
                            Unchecked="OnToggleChanged" />
                  <CheckBox x:Name="OutlineCheckBox"
                            Content="Outline"
                            IsThreeState="True"
                            Grid.Row="1"
                            Grid.Column="1"
                            Checked="OnToggleChanged"
                            Unchecked="OnToggleChanged" />
                  <CheckBox x:Name="ShadowCheckBox"
                            Content="Shadow"
                            IsThreeState="True"
                            Grid.Row="2"
                            Grid.Column="0"
                            Checked="OnToggleChanged"
                            Unchecked="OnToggleChanged" />
                  <CheckBox x:Name="EmbossCheckBox"
                            Content="Emboss"
                            IsThreeState="True"
                            Grid.Row="2"
                            Grid.Column="1"
                            Checked="OnToggleChanged"
                            Unchecked="OnToggleChanged" />
                  <CheckBox x:Name="ImprintCheckBox"
                            Content="Imprint"
                            IsThreeState="True"
                            Grid.Row="3"
                            Grid.Column="0"
                            Checked="OnToggleChanged"
                            Unchecked="OnToggleChanged" />
                  <StackPanel Grid.Row="3"
                              Grid.Column="1"
                              Orientation="Horizontal"
                              Spacing="6">
                    <TextBlock Text="Position:"
                               VerticalAlignment="Center" />
                    <ComboBox x:Name="VerticalPositionCombo"
                              Width="140"
                              SelectionChanged="OnSelectionChanged" />
                  </StackPanel>
                </Grid>
              </StackPanel>
            </Border>

            <Border BorderBrush="#D0D0D0"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="8">
              <StackPanel Spacing="8">
                <TextBlock Text="Preview"
                           FontWeight="SemiBold" />
                <Border Background="#FFFFFF"
                        BorderBrush="#C8C8C8"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="12">
                  <TextBlock x:Name="PreviewText"
                             Text="AaBbYyZz"
                             FontSize="24"
                             TextAlignment="Center" />
                </Border>
              </StackPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <TabItem Header="Advanced">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <StackPanel Spacing="12">
            <Border BorderBrush="#D0D0D0"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="8">
              <StackPanel Spacing="8">
                <TextBlock Text="Character spacing"
                           FontWeight="SemiBold" />
                <Grid ColumnDefinitions="Auto,*"
                      RowDefinitions="Auto,Auto,Auto"
                      ColumnSpacing="8"
                      RowSpacing="6">
                  <TextBlock Text="Scale:"
                             VerticalAlignment="Center" />
                  <ComboBox x:Name="CharacterScaleCombo"
                            Grid.Column="1"
                            Width="120"
                            IsEditable="True"
                            SelectionChanged="OnSelectionChanged" />

                  <TextBlock Grid.Row="1"
                             Text="Spacing:"
                             VerticalAlignment="Center" />
                  <StackPanel Grid.Row="1"
                              Grid.Column="1"
                              Orientation="Horizontal"
                              Spacing="6">
                    <ComboBox x:Name="CharacterSpacingCombo"
                              Width="140"
                              SelectionChanged="OnCharacterSpacingChanged" />
                    <TextBlock Text="By:"
                               VerticalAlignment="Center" />
                    <TextBox x:Name="CharacterSpacingByTextBox"
                             Width="70"
                             HorizontalContentAlignment="Right"
                             TextChanged="OnTextChanged" />
                    <TextBlock Text="pt"
                               VerticalAlignment="Center" />
                  </StackPanel>

                  <TextBlock Grid.Row="2"
                             Text="Position:"
                             VerticalAlignment="Center" />
                  <StackPanel Grid.Row="2"
                              Grid.Column="1"
                              Orientation="Horizontal"
                              Spacing="6">
                    <ComboBox x:Name="CharacterPositionCombo"
                              Width="140"
                              SelectionChanged="OnCharacterPositionChanged" />
                    <TextBlock Text="By:"
                               VerticalAlignment="Center" />
                    <TextBox x:Name="CharacterPositionByTextBox"
                             Width="70"
                             HorizontalContentAlignment="Right"
                             TextChanged="OnTextChanged" />
                    <TextBlock Text="pt"
                               VerticalAlignment="Center" />
                  </StackPanel>
                </Grid>
              </StackPanel>
            </Border>

            <Border BorderBrush="#D0D0D0"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="8">
              <StackPanel Spacing="8">
                <TextBlock Text="Preview"
                           FontWeight="SemiBold" />
                <Border Background="#FFFFFF"
                        BorderBrush="#C8C8C8"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="12">
                  <TextBlock x:Name="PreviewTextAdvanced"
                             Text="AaBbYyZz"
                             FontSize="24"
                             TextAlignment="Center" />
                </Border>
              </StackPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>
      </TabItem>
    </TabControl>

    <StackPanel Grid.Row="1"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Spacing="8"
                Margin="0,12,0,0">
      <Button Content="OK"
              Width="90"
              Click="OnOkClick" />
      <Button Content="Cancel"
              Width="90"
              Click="OnCancelClick" />
    </StackPanel>
  </Grid>
</Window>
