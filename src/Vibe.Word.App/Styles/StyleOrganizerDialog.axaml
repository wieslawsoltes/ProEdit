<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:editing="clr-namespace:Vibe.Office.Editing;assembly=Vibe.Office.Editing"
        x:Class="Vibe.Word.App.StyleOrganizerDialog"
        Width="760"
        Height="520"
        WindowStartupLocation="CenterOwner"
        Title="Style Organizer">
  <Grid Margin="12"
        ColumnDefinitions="*,Auto,*"
        RowDefinitions="Auto,*,Auto">
    <StackPanel Grid.Row="0"
                Grid.ColumnSpan="3"
                Orientation="Horizontal"
                Spacing="8"
                Margin="0,0,0,8">
      <Button x:Name="LoadSourceButton"
              Content="Load Styles From File" />
      <TextBlock x:Name="SourcePathText" />
    </StackPanel>

    <StackPanel Grid.Row="1"
                Grid.Column="0"
                Spacing="6">
      <TextBlock Text="Current document" />
      <ListBox x:Name="CurrentStylesList"
               SelectionMode="Multiple">
        <ListBox.ItemTemplate>
          <DataTemplate x:DataType="editing:EditorStyleInfo">
            <StackPanel Spacing="2">
              <TextBlock Text="{Binding Name}" />
              <TextBlock Text="{Binding Type}"
                         FontSize="11"
                         Foreground="#666666" />
            </StackPanel>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </StackPanel>

    <StackPanel Grid.Row="1"
                Grid.Column="1"
                Spacing="8"
                VerticalAlignment="Center">
      <Button x:Name="CopyFromSourceButton"
              Content="Copy From" />
      <Button x:Name="CopyToSourceButton"
              Content="Copy To" />
      <Button x:Name="ExportButton"
              Content="Export Selected" />
    </StackPanel>

    <StackPanel Grid.Row="1"
                Grid.Column="2"
                Spacing="6">
      <TextBlock Text="From file" />
      <ListBox x:Name="SourceStylesList"
               SelectionMode="Multiple">
        <ListBox.ItemTemplate>
          <DataTemplate x:DataType="editing:EditorStyleInfo">
            <StackPanel Spacing="2">
              <TextBlock Text="{Binding Name}" />
              <TextBlock Text="{Binding Type}"
                         FontSize="11"
                         Foreground="#666666" />
            </StackPanel>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </StackPanel>

    <StackPanel Grid.Row="2"
                Grid.ColumnSpan="3"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Spacing="8"
                Margin="0,8,0,0">
      <Button x:Name="CloseButton"
              Content="Close" />
    </StackPanel>
  </Grid>
</Window>
