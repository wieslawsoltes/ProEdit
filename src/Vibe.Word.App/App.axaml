<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Vibe.Word.App.App"
             RequestedThemeVariant="Default">
             <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.Styles>
        <FluentTheme />
    </Application.Styles>

    <Application.Resources>
        <ResourceDictionary>
            <Color x:Key="RibbonSurfaceColor">#EEF1F5</Color>
            <SolidColorBrush x:Key="RibbonSurfaceBrush" Color="{StaticResource RibbonSurfaceColor}" />
            <x:String x:Key="RibbonIcon.Open">📂</x:String>
            <x:String x:Key="RibbonIcon.Save">💾</x:String>
            <x:String x:Key="RibbonIcon.SaveAs">💾➕</x:String>
            <x:String x:Key="RibbonIcon.Layout">📐</x:String>
            <x:String x:Key="RibbonIcon.Invisibles">👁️</x:String>
            <x:String x:Key="RibbonIcon.Text">🔤</x:String>
            <x:String x:Key="RibbonIcon.Cache">🗄️</x:String>
            <x:String x:Key="RibbonIcon.Equation">🧮</x:String>
            <x:String x:Key="RibbonIcon.Paste">📋</x:String>
            <x:String x:Key="RibbonIcon.Cut">✂️</x:String>
            <x:String x:Key="RibbonIcon.Copy">📄</x:String>
            <x:String x:Key="RibbonIcon.FormatPainter">🖌️</x:String>
            <x:String x:Key="RibbonIcon.FontFamily">🔤</x:String>
            <x:String x:Key="RibbonIcon.FontSize">🔠</x:String>
            <x:String x:Key="RibbonIcon.GrowFont">🔍➕</x:String>
            <x:String x:Key="RibbonIcon.ShrinkFont">🔍➖</x:String>
            <x:String x:Key="RibbonIcon.ChangeCase">🔡</x:String>
            <x:String x:Key="RibbonIcon.ClearFormatting">🧹</x:String>
            <x:String x:Key="RibbonIcon.Bold">🅱️</x:String>
            <x:String x:Key="RibbonIcon.Italic">✒️</x:String>
            <x:String x:Key="RibbonIcon.Underline">〰️</x:String>
            <x:String x:Key="RibbonIcon.TextEffects">✨</x:String>
            <x:String x:Key="RibbonIcon.Strikethrough">➖</x:String>
            <x:String x:Key="RibbonIcon.Superscript">⬆️</x:String>
            <x:String x:Key="RibbonIcon.Subscript">⬇️</x:String>
            <x:String x:Key="RibbonIcon.Highlight">🖍️</x:String>
            <x:String x:Key="RibbonIcon.FontColor">🎨</x:String>
            <x:String x:Key="RibbonIcon.Bullets">🔘</x:String>
            <x:String x:Key="RibbonIcon.Numbering">🔢</x:String>
            <x:String x:Key="RibbonIcon.Multilevel">🧮</x:String>
            <x:String x:Key="RibbonIcon.IndentDecrease">↩️</x:String>
            <x:String x:Key="RibbonIcon.IndentIncrease">↪️</x:String>
            <x:String x:Key="RibbonIcon.Sort">🔀</x:String>
            <x:String x:Key="RibbonIcon.AlignLeft">⬅️</x:String>
            <x:String x:Key="RibbonIcon.AlignCenter">↔️</x:String>
            <x:String x:Key="RibbonIcon.AlignRight">➡️</x:String>
            <x:String x:Key="RibbonIcon.AlignJustify">📰</x:String>
            <x:String x:Key="RibbonIcon.LineSpacing">↕️</x:String>
            <x:String x:Key="RibbonIcon.Shading">🟨</x:String>
            <x:String x:Key="RibbonIcon.Borders">⬛️</x:String>
            <x:String x:Key="RibbonIcon.Styles">🧾</x:String>
            <x:String x:Key="RibbonIcon.Find">🔍</x:String>
            <x:String x:Key="RibbonIcon.Replace">🔁</x:String>
            <x:String x:Key="RibbonIcon.Select">✅</x:String>
            <x:String x:Key="RibbonIcon.Dropdown">🔽</x:String>
        </ResourceDictionary>
    </Application.Resources>
</Application>
