            <x:String x:Key="RibbonIcon.MailMerge">📬</x:String>
            <x:String x:Key="RibbonIcon.Print">🖨️</x:String>
            <x:String x:Key="RibbonIcon.Comment">💬</x:String>
            <x:String x:Key="RibbonIcon.TrackChanges">🕵️</x:String>
            <x:String x:Key="RibbonIcon.Reject">❌</x:String>
            <x:String x:Key="RibbonIcon.Thesaurus">📚</x:String>
            <x:String x:Key="RibbonIcon.WordCount">🔢</x:String>
            <x:String x:Key="RibbonIcon.Pen">🖊️</x:String>
            <x:String x:Key="RibbonIcon.Pencil">✏️</x:String>
