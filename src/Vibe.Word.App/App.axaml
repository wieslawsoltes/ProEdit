            <x:String x:Key="RibbonIcon.Signature">✍️</x:String>
            <x:String x:Key="RibbonIcon.DateTime">🕒</x:String>
            <x:String x:Key="RibbonIcon.Object">📎</x:String>
            <x:String x:Key="RibbonIcon.Symbol">🔣</x:String>
            <x:String x:Key="RibbonIcon.Theme">🎨</x:String>
            <x:String x:Key="RibbonIcon.Watermark">💧</x:String>
            <x:String x:Key="RibbonIcon.PageColor">🖍️</x:String>
            <x:String x:Key="RibbonIcon.PageBorders">🧱</x:String>
