<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Vibe.Word.App.HyperlinkDialog"
        Width="420"
        Height="260"
        WindowStartupLocation="CenterOwner"
        Title="Insert Hyperlink">
  <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto"
        ColumnDefinitions="Auto,*"
        RowSpacing="8"
        ColumnSpacing="10"
        Margin="12">
    <TextBlock Text="Text to display:"
               VerticalAlignment="Center" />
    <TextBox x:Name="DisplayTextBox"
             Grid.Column="1"
             MinWidth="240" />

    <TextBlock Grid.Row="1"
               Text="Address:"
               VerticalAlignment="Center" />
    <TextBox x:Name="AddressTextBox"
             Grid.Row="1"
             Grid.Column="1"
             TextChanged="OnFieldChanged" />

    <TextBlock Grid.Row="2"
               Text="ScreenTip:"
               VerticalAlignment="Center" />
    <TextBox x:Name="TooltipTextBox"
             Grid.Row="2"
             Grid.Column="1" />

    <TextBlock Grid.Row="3"
               Text="Anchor:"
               VerticalAlignment="Center" />
    <TextBox x:Name="AnchorTextBox"
             Grid.Row="3"
             Grid.Column="1"
             TextChanged="OnFieldChanged" />

    <TextBlock x:Name="ValidationText"
               Grid.Row="4"
               Grid.ColumnSpan="2"
               Foreground="#C00000"
               IsVisible="False"
               TextWrapping="Wrap" />

    <StackPanel Grid.Row="5"
                Grid.ColumnSpan="2"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Spacing="8">
      <Button x:Name="InsertButton"
              Content="Insert"
              Width="80"
              Click="OnInsertClick" />
      <Button Content="Cancel"
              Width="80"
              Click="OnCancelClick" />
    </StackPanel>
  </Grid>
</Window>
