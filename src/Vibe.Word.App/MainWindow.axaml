<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Vibe.Word.App"
        xmlns:ribbon="clr-namespace:Vibe.Office.Ribbon.Avalonia;assembly=Vibe.Office.Ribbon.Avalonia"
        mc:Ignorable="d" d:DesignWidth="1024" d:DesignHeight="768"
        x:Class="Vibe.Word.App.MainWindow"
        Background="{DynamicResource RibbonSurfaceBrush}"
        Title="Vibe Word">
    <Grid Background="{DynamicResource RibbonSurfaceBrush}">
        <DockPanel>
            <ribbon:RibbonControl x:Name="Ribbon" DockPanel.Dock="Top" />
            <Border x:Name="StatusBar"
                    DockPanel.Dock="Bottom"
                    Background="{DynamicResource RibbonSurfaceBrush}"
                    BorderBrush="#D0D4DB"
                    BorderThickness="0,1,0,0"
                    Padding="8,4">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <StackPanel Orientation="Horizontal"
                                Spacing="12"
                                VerticalAlignment="Center">
                        <TextBlock x:Name="StatusPageText"
                                   Text="Page 1 of 1"
                                   Foreground="#404040" />
                    </StackPanel>
                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                Spacing="6"
                                VerticalAlignment="Center">
                        <Button x:Name="ZoomOutButton"
                                Content="{DynamicResource RibbonIcon.ZoomOut}"
                                Width="32"
                                Height="22"
                                FontSize="12"
                                Padding="0"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center" />
                        <Slider x:Name="ZoomSlider"
                                Width="150"
                                Minimum="10"
                                Maximum="500"
                                SmallChange="10"
                                LargeChange="50"
                                Value="100"
                                VerticalAlignment="Center" />
                        <Button x:Name="ZoomInButton"
                                Content="{DynamicResource RibbonIcon.ZoomIn}"
                                Width="32"
                                Height="22"
                                FontSize="12"
                                Padding="0"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center" />
                        <Button x:Name="ZoomResetButton"
                                Content="100%"
                                MinWidth="64"
                                Height="24"
                                Padding="8,0"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center" />
                    </StackPanel>
                </Grid>
            </Border>
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Border x:Name="NavigationPane"
                        Grid.Column="0"
                        Width="220"
                        Background="#F7F7F7"
                        BorderBrush="#DDDDDD"
                        BorderThickness="0,0,1,0"
                        IsVisible="False">
                    <ListBox x:Name="NavigationPaneList"
                             Margin="8">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}"
                                           Foreground="#404040"
                                           TextWrapping="Wrap" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>
                <Grid Grid.Column="1"
                      ColumnDefinitions="Auto,*"
                      RowDefinitions="Auto,*">
                    <local:RulerCornerControl x:Name="RulerCorner"
                                              Grid.Row="0"
                                              Grid.Column="0"
                                              Width="26"
                                              Height="26"
                                              SurfaceColor="{DynamicResource RibbonSurfaceColor}" />
                    <local:HorizontalRuler x:Name="HorizontalRuler"
                                           Grid.Row="0"
                                           Grid.Column="1"
                                           Height="26"
                                           SurfaceColor="{DynamicResource RibbonSurfaceColor}" />
                    <local:VerticalRuler x:Name="VerticalRuler"
                                         Grid.Row="1"
                                         Grid.Column="0"
                                         Width="26"
                                         SurfaceColor="{DynamicResource RibbonSurfaceColor}" />
                    <ScrollViewer Grid.Row="1"
                                  Grid.Column="1"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto">
                        <local:DocumentView x:Name="EditorView"
                                            SurfaceColor="{DynamicResource RibbonSurfaceColor}" />
                    </ScrollViewer>
                </Grid>
                <Border x:Name="EquationEditorPanel"
                        Grid.Column="2"
                        Width="320"
                        Background="#FBFBFB"
                        BorderBrush="#DDDDDD"
                        BorderThickness="1,0,0,0">
                    <local:EquationEditor x:Name="EquationEditor" />
                </Border>
            </Grid>
        </DockPanel>
        <Border x:Name="LoadingOverlay"
                Background="#80000000"
                IsVisible="False">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="8">
                <TextBlock x:Name="LoadingText"
                           Text="Loading..."
                           Foreground="White"
                           FontSize="14"
                           HorizontalAlignment="Center" />
                <ProgressBar x:Name="LoadingProgressBar"
                             Width="240"
                             Height="6"
                             IsIndeterminate="True" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
