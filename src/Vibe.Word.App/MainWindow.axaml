<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Vibe.Word.App"
        xmlns:ribbon="clr-namespace:Vibe.Office.Ribbon.Avalonia;assembly=Vibe.Office.Ribbon.Avalonia"
        mc:Ignorable="d" d:DesignWidth="1024" d:DesignHeight="768"
        x:Class="Vibe.Word.App.MainWindow"
        Background="{DynamicResource RibbonSurfaceBrush}"
        Title="Vibe Word">
    <Grid Background="{DynamicResource RibbonSurfaceBrush}">
        <DockPanel>
            <ribbon:RibbonControl x:Name="Ribbon" DockPanel.Dock="Top" />
            <Border x:Name="StatusBar"
                    DockPanel.Dock="Bottom"
                    Background="{DynamicResource RibbonSurfaceBrush}"
                    BorderBrush="#D0D4DB"
                    BorderThickness="0,1,0,0"
                    Padding="8,4">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <StackPanel Orientation="Horizontal"
                                Spacing="12"
                                VerticalAlignment="Center">
                        <TextBlock x:Name="StatusPageText"
                                   Text="Page 1 of 1"
                                   Foreground="#404040" />
                    </StackPanel>
                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                Spacing="6"
                                VerticalAlignment="Center">
                        <Button x:Name="ZoomOutButton"
                                Content="{DynamicResource RibbonIcon.ZoomOut}"
                                Width="32"
                                Height="22"
                                FontSize="12"
                                Padding="0"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center" />
                        <Slider x:Name="ZoomSlider"
                                Width="150"
                                Minimum="10"
                                Maximum="500"
                                SmallChange="10"
                                LargeChange="50"
                                Value="100"
                                VerticalAlignment="Center" />
                        <Button x:Name="ZoomInButton"
                                Content="{DynamicResource RibbonIcon.ZoomIn}"
                                Width="32"
                                Height="22"
                                FontSize="12"
                                Padding="0"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center" />
                        <Button x:Name="ZoomResetButton"
                                Content="100%"
                                MinWidth="64"
                                Height="24"
                                Padding="8,0"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center" />
                    </StackPanel>
                </Grid>
            </Border>
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Border x:Name="NavigationPane"
                        Grid.Column="0"
                        Width="220"
                        Background="#F7F7F7"
                        BorderBrush="#DDDDDD"
                        BorderThickness="0,0,1,0"
                        IsVisible="False">
                    <TabControl TabStripPlacement="Top">
                        <TabItem Header="Headings">
                            <ListBox x:Name="NavigationPaneList"
                                     Margin="8">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}"
                                                   Foreground="#404040"
                                                   TextWrapping="Wrap" />
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </TabItem>
                        <TabItem Header="Pages">
                            <ListBox x:Name="PagePaneList"
                                     Margin="8">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}"
                                                   Foreground="#404040"
                                                   TextWrapping="Wrap" />
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </TabItem>
                    </TabControl>
                </Border>
                <Grid Grid.Column="1"
                      ColumnDefinitions="Auto,*"
                      RowDefinitions="Auto,*">
                    <local:RulerCornerControl x:Name="RulerCorner"
                                              Grid.Row="0"
                                              Grid.Column="0"
                                              Width="26"
                                              Height="26"
                                              SurfaceColor="{DynamicResource RibbonSurfaceColor}" />
                    <local:HorizontalRuler x:Name="HorizontalRuler"
                                           Grid.Row="0"
                                           Grid.Column="1"
                                           Height="26"
                                           SurfaceColor="{DynamicResource RibbonSurfaceColor}" />
                    <local:VerticalRuler x:Name="VerticalRuler"
                                         Grid.Row="1"
                                         Grid.Column="0"
                                         Width="26"
                                         SurfaceColor="{DynamicResource RibbonSurfaceColor}" />
                    <ScrollViewer Grid.Row="1"
                                  Grid.Column="1"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto">
                        <local:DocumentView x:Name="EditorView"
                                            SurfaceColor="{DynamicResource RibbonSurfaceColor}" />
                    </ScrollViewer>
                </Grid>
                <Grid Grid.Column="2"
                      RowDefinitions="Auto,*">
                    <Border x:Name="ReviewPane"
                            Grid.Row="0"
                            Width="320"
                            Height="320"
                            Background="#F7F7F7"
                            BorderBrush="#DDDDDD"
                            BorderThickness="1,0,0,1"
                            IsVisible="False">
                        <DockPanel>
                            <Border DockPanel.Dock="Top"
                                    Background="#ECEFF3"
                                    Padding="8">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Text="Reviewing Pane"
                                               Foreground="#404040"
                                               FontWeight="SemiBold" />
                                    <Button x:Name="ReviewPaneCloseButton"
                                            Grid.Column="1"
                                            Content="Close"
                                            Height="24"
                                            Padding="8,0"
                                            HorizontalContentAlignment="Center"
                                            VerticalContentAlignment="Center" />
                                </Grid>
                            </Border>
                            <TabControl>
                                <TabItem Header="Comments">
                                    <Grid Margin="8"
                                          RowDefinitions="*,Auto,Auto">
                                        <ListBox x:Name="ReviewCommentsList"
                                                 Grid.Row="0">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate x:CompileBindings="False">
                                                    <StackPanel Spacing="2">
                                                        <TextBlock Text="{Binding Header}"
                                                                   FontSize="12"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#333333" />
                                                        <TextBlock Text="{Binding Preview}"
                                                                   FontSize="11"
                                                                   Foreground="#555555"
                                                                   TextWrapping="Wrap"
                                                                   MaxHeight="48" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                        <TextBlock Grid.Row="1"
                                                   Margin="0,8,0,4"
                                                   Text="Comment:"
                                                   Foreground="#404040" />
                                        <StackPanel Grid.Row="2"
                                                    Spacing="6">
                                            <TextBox x:Name="ReviewCommentEditor"
                                                     AcceptsReturn="True"
                                                     TextWrapping="Wrap"
                                                     Height="72" />
                                            <StackPanel Orientation="Horizontal"
                                                        Spacing="6"
                                                        HorizontalAlignment="Right">
                                                <Button x:Name="ReviewCommentApplyButton"
                                                        Content="Apply"
                                                        Padding="10,2"
                                                        Height="24" />
                                                <Button x:Name="ReviewCommentDeleteButton"
                                                        Content="Delete"
                                                        Padding="10,2"
                                                        Height="24" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                </TabItem>
                                <TabItem Header="Changes">
                                    <Grid Margin="8"
                                          RowDefinitions="*,Auto">
                                        <ListBox x:Name="ReviewChangesList"
                                                 Grid.Row="0">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate x:CompileBindings="False">
                                                    <StackPanel Spacing="2">
                                                        <TextBlock Text="{Binding Header}"
                                                                   FontSize="12"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#333333" />
                                                        <TextBlock Text="{Binding Preview}"
                                                                   FontSize="11"
                                                                   Foreground="#555555"
                                                                   TextWrapping="Wrap"
                                                                   MaxHeight="48" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                        <StackPanel Grid.Row="1"
                                                    Orientation="Horizontal"
                                                    Spacing="6"
                                                    HorizontalAlignment="Right"
                                                    Margin="0,8,0,0">
                                            <Button x:Name="ReviewChangePreviousButton"
                                                    Content="Previous"
                                                    Padding="10,2"
                                                    Height="24" />
                                            <Button x:Name="ReviewChangeNextButton"
                                                    Content="Next"
                                                    Padding="10,2"
                                                    Height="24" />
                                            <Button x:Name="ReviewChangeAcceptButton"
                                                    Content="Accept"
                                                    Padding="10,2"
                                                    Height="24" />
                                            <Button x:Name="ReviewChangeRejectButton"
                                                    Content="Reject"
                                                    Padding="10,2"
                                                    Height="24" />
                                        </StackPanel>
                                    </Grid>
                                </TabItem>
                            </TabControl>
                        </DockPanel>
                    </Border>
                    <Border x:Name="EquationEditorPanel"
                            Grid.Row="1"
                            Width="320"
                            Background="#FBFBFB"
                            BorderBrush="#DDDDDD"
                            BorderThickness="1,0,0,0">
                        <local:EquationEditor x:Name="EquationEditor" />
                    </Border>
                </Grid>
            </Grid>
        </DockPanel>
        <Border x:Name="LoadingOverlay"
                Background="#80000000"
                IsVisible="False">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="8">
                <TextBlock x:Name="LoadingText"
                           Text="Loading..."
                           Foreground="White"
                           FontSize="14"
                           HorizontalAlignment="Center" />
                <ProgressBar x:Name="LoadingProgressBar"
                             Width="240"
                             Height="6"
                             IsIndeterminate="True" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
