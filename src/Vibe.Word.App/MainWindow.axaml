<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Vibe.Word.App"
        mc:Ignorable="d" d:DesignWidth="1024" d:DesignHeight="768"
        x:Class="Vibe.Word.App.MainWindow"
        Title="Vibe Word">
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#F5F5F5" Padding="8">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button x:Name="OpenButton" Content="Open" />
                <Button x:Name="SaveButton" Content="Save" />
                <CheckBox x:Name="ShowInvisiblesCheckBox" Content="Show Invisibles" />
                <CheckBox x:Name="ShowLayoutCheckBox" Content="Show Layout" />
                <CheckBox x:Name="UseHarfBuzzCheckBox" Content="Use HarfBuzz" />
                <CheckBox x:Name="UsePictureCacheCheckBox" Content="Use Page Cache" />
            </StackPanel>
        </Border>
        <Grid ColumnDefinitions="*,Auto">
            <ScrollViewer Grid.Column="0"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto">
                <local:DocumentView x:Name="EditorView" />
            </ScrollViewer>
            <Border x:Name="EquationEditorPanel"
                    Grid.Column="1"
                    Width="320"
                    Background="#FBFBFB"
                    BorderBrush="#DDDDDD"
                    BorderThickness="1,0,0,0">
                <local:EquationEditor x:Name="EquationEditor" />
            </Border>
        </Grid>
    </DockPanel>
</Window>
