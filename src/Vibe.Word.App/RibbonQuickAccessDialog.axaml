<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:input="using:Avalonia.Input"
        xmlns:local="clr-namespace:Vibe.Word.App"
        x:Class="Vibe.Word.App.RibbonQuickAccessDialog"
        x:DataType="local:RibbonQuickAccessDialogViewModel"
        Width="460"
        Height="520"
        WindowStartupLocation="CenterOwner"
        Title="Customize Quick Access Toolbar">
  <Grid RowDefinitions="Auto,*,Auto"
        RowSpacing="12"
        Margin="16">
    <TextBlock Text="Customize Quick Access Toolbar"
               FontSize="16"
               FontWeight="SemiBold" />
    <Border Grid.Row="1"
            BorderBrush="#D0D4DB"
            BorderThickness="1"
            CornerRadius="4"
            Padding="8">
      <ListBox x:Name="CandidateList"
               ItemsSource="{Binding Candidates}"
               input:DragDrop.AllowDrop="True"
               SelectionMode="Single"
               PointerPressed="OnCandidatePointerPressed"
               PointerMoved="OnCandidatePointerMoved"
               PointerReleased="OnCandidatePointerReleased"
               input:DragDrop.DragOver="OnCandidateDragOver"
               input:DragDrop.Drop="OnCandidateDrop">
        <ListBox.ItemTemplate>
          <DataTemplate x:DataType="local:RibbonQuickAccessCandidate">
            <CheckBox IsChecked="{Binding IsSelected}"
                      Margin="0,4,0,0">
              <StackPanel Orientation="Horizontal"
                          Spacing="6">
                <TextBlock Text="{Binding Label}" />
                <TextBlock Text="{Binding GroupPath}"
                           Foreground="#707070"
                           FontSize="11" />
              </StackPanel>
            </CheckBox>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </Border>
    <StackPanel Grid.Row="2"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Spacing="8">
      <Button Content="OK"
              Width="80"
              Click="OnOkClick" />
      <Button Content="Cancel"
              Width="80"
              Click="OnCancelClick" />
    </StackPanel>
  </Grid>
</Window>
