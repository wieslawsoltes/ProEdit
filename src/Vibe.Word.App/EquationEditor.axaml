<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Vibe.Word.App.EquationEditor">
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#F0F0F0" Padding="8">
            <StackPanel Spacing="6">
                <TextBlock Text="Equation Editor" FontWeight="Bold" />
                <WrapPanel>
                    <Button x:Name="AddRunButton" Content="Run" Margin="0,0,6,6" />
                    <Button x:Name="AddRowButton" Content="Row" Margin="0,0,6,6" />
                    <Button x:Name="AddFractionButton" Content="Fraction" Margin="0,0,6,6" />
                    <Button x:Name="AddScriptButton" Content="Script" Margin="0,0,6,6" />
                    <Button x:Name="AddRadicalButton" Content="Radical" Margin="0,0,6,6" />
                    <Button x:Name="AddAccentButton" Content="Accent" Margin="0,0,6,6" />
                    <Button x:Name="AddDelimiterButton" Content="Delimiter" Margin="0,0,6,6" />
                    <Button x:Name="AddNaryButton" Content="N-ary" Margin="0,0,6,6" />
                    <Button x:Name="AddMatrixButton" Content="Matrix" Margin="0,0,6,6" />
                </WrapPanel>
            </StackPanel>
        </Border>
        <Border DockPanel.Dock="Bottom" Background="#FAFAFA" Padding="8">
            <StackPanel Spacing="6">
                <TextBlock x:Name="SelectedNodeText" Text="No equation selected" />
                <StackPanel x:Name="RunEditorPanel" Spacing="4" IsVisible="False">
                    <TextBlock Text="Run text" />
                    <TextBox x:Name="RunTextBox" />
                </StackPanel>
                <StackPanel x:Name="AccentEditorPanel" Spacing="4" IsVisible="False">
                    <TextBlock Text="Accent char" />
                    <TextBox x:Name="AccentTextBox" />
                </StackPanel>
                <StackPanel x:Name="DelimiterEditorPanel" Spacing="4" IsVisible="False">
                    <TextBlock Text="Delimiter begin/end/separator" />
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBox x:Name="DelimiterBeginTextBox" Width="40" Watermark="(" />
                        <TextBox x:Name="DelimiterEndTextBox" Width="40" Watermark=")" />
                        <TextBox x:Name="DelimiterSeparatorTextBox" Width="40" Watermark="," />
                    </StackPanel>
                </StackPanel>
                <StackPanel x:Name="NaryEditorPanel" Spacing="4" IsVisible="False">
                    <TextBlock Text="Operator char" />
                    <TextBox x:Name="NaryOperatorTextBox" />
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <CheckBox x:Name="NaryHideSubCheckBox" Content="Hide sub" />
                        <CheckBox x:Name="NaryHideSupCheckBox" Content="Hide sup" />
                    </StackPanel>
                </StackPanel>
                <StackPanel x:Name="MatrixEditorPanel" Spacing="4" IsVisible="False">
                    <TextBlock Text="Matrix actions" />
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Button x:Name="AddMatrixRowButton" Content="Add row" />
                        <Button x:Name="AddMatrixColumnButton" Content="Add column" />
                    </StackPanel>
                </StackPanel>
                <Button x:Name="RemoveNodeButton" Content="Remove node" />
            </StackPanel>
        </Border>
        <ScrollViewer>
            <TreeView x:Name="EquationTree" />
        </ScrollViewer>
    </DockPanel>
</UserControl>
