<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:editing="clr-namespace:Vibe.Office.Editing;assembly=Vibe.Office.Editing"
        x:Class="Vibe.Word.App.StylesPaneWindow"
        Width="320"
        Height="420"
        MinWidth="260"
        MinHeight="300"
        Title="Styles">
  <DockPanel Margin="12">
    <TextBlock x:Name="PaneTitle"
               DockPanel.Dock="Top"
               Text="Styles"
               FontSize="14"
               FontWeight="SemiBold"
               Margin="0,0,0,8" />
    <ListBox x:Name="StylesList"
             DockPanel.Dock="Top"
             MinHeight="200">
      <ListBox.ItemTemplate>
        <DataTemplate x:DataType="editing:EditorParagraphStyleInfo">
          <TextBlock Text="{Binding Name}" />
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>
    <StackPanel DockPanel.Dock="Bottom"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Spacing="8"
                Margin="0,8,0,0">
      <Button x:Name="ApplyButton"
              Content="Apply" />
      <Button x:Name="CloseButton"
              Content="Close" />
    </StackPanel>
  </DockPanel>
</Window>
