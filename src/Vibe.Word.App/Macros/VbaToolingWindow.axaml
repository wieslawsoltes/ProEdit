<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:docs="clr-namespace:Vibe.Office.Documents;assembly=Vibe.Office.Documents"
        xmlns:vba="clr-namespace:Vibe.Office.Vba.Runtime;assembly=Vibe.Office.Vba.Runtime"
        x:Class="Vibe.Word.App.VbaToolingWindow"
        Width="1200"
        Height="720"
        WindowStartupLocation="CenterOwner"
        Title="VBA Editor">
  <Grid ColumnDefinitions="240,*,300"
        RowDefinitions="Auto,*,Auto"
        ColumnSpacing="12"
        RowSpacing="10"
        Margin="12">
    <StackPanel Grid.Row="0"
                Grid.ColumnSpan="3"
                Orientation="Horizontal"
                Spacing="6">
      <Button Content="Debug"
              Width="90"
              Click="OnDebugClick" />
      <Button Content="Continue"
              Width="90"
              Click="OnContinueClick" />
      <Button Content="Break"
              Width="90"
              Click="OnBreakClick" />
      <Button Content="Step In"
              Width="90"
              Click="OnStepInClick" />
      <Button Content="Step Over"
              Width="90"
              Click="OnStepOverClick" />
      <Button Content="Step Out"
              Width="90"
              Click="OnStepOutClick" />
      <Button Content="Stop"
              Width="90"
              Click="OnStopClick" />
    </StackPanel>

    <StackPanel Grid.Row="1"
                Grid.Column="0"
                Spacing="8">
      <TextBlock Text="Modules"
                 FontWeight="Bold" />
      <Border BorderBrush="#D0D4DB"
              BorderThickness="1"
              CornerRadius="4"
              Padding="6">
        <ListBox x:Name="ModulesList"
                 SelectionMode="Single"
                 SelectionChanged="OnModuleSelectionChanged">
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="docs:VbaModuleInfo">
              <TextBlock Text="{Binding Name}" />
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Border>

      <TextBlock Text="Procedures"
                 FontWeight="Bold" />
      <Border BorderBrush="#D0D4DB"
              BorderThickness="1"
              CornerRadius="4"
              Padding="6">
        <ListBox x:Name="ProceduresList"
                 SelectionMode="Single"
                 DoubleTapped="OnProcedureDoubleTapped" />
      </Border>

      <StackPanel Orientation="Horizontal"
                  Spacing="6">
        <Button Content="Save"
                Width="80"
                Click="OnSaveClick" />
        <Button Content="Check"
                Width="80"
                Click="OnValidateClick" />
      </StackPanel>

      <TextBlock Text="Recordings"
                 FontWeight="Bold" />
      <Border BorderBrush="#D0D4DB"
              BorderThickness="1"
              CornerRadius="4"
              Padding="6">
        <ListBox x:Name="RecordingsList"
                 SelectionMode="Single">
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="docs:MacroDefinition">
              <TextBlock Text="{Binding Name}" />
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Border>
      <Button Content="Convert to VBA"
              Click="OnConvertRecordingClick" />

      <TextBlock Text="References"
                 FontWeight="Bold" />
      <Border BorderBrush="#D0D4DB"
              BorderThickness="1"
              CornerRadius="4"
              Padding="6">
        <ListBox x:Name="ReferencesList"
                 SelectionMode="Single">
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="docs:VbaProjectReference">
              <TextBlock Text="{Binding Name}" />
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Border>
      <StackPanel Orientation="Horizontal"
                  Spacing="6">
        <Button Content="Add"
                Width="80"
                Click="OnAddReferenceClick" />
        <Button Content="Remove"
                Width="80"
                Click="OnRemoveReferenceClick" />
      </StackPanel>
    </StackPanel>

    <Grid Grid.Row="1"
          Grid.Column="1"
          RowDefinitions="*,Auto"
          RowSpacing="6">
      <TextBox x:Name="SourceEditor"
               AcceptsReturn="True"
               TextWrapping="NoWrap"
               FontFamily="Consolas"
               TextChanged="OnSourceTextChanged"
               ScrollViewer.VerticalScrollBarVisibility="Auto"
               ScrollViewer.HorizontalScrollBarVisibility="Auto" />
      <StackPanel Grid.Row="1"
                  Orientation="Horizontal"
                  HorizontalAlignment="Right"
                  Spacing="6">
        <TextBlock Text="Breakpoint Line:"
                   VerticalAlignment="Center" />
        <TextBox x:Name="BreakpointLineBox"
                 Width="60" />
        <Button Content="Add"
                Width="70"
                Click="OnAddBreakpointClick" />
      </StackPanel>
    </Grid>

    <TabControl Grid.Row="1"
                Grid.Column="2">
      <TabItem Header="Locals">
        <Border BorderBrush="#D0D4DB"
                BorderThickness="1"
                CornerRadius="4"
                Padding="6">
          <ListBox x:Name="LocalsList" />
        </Border>
      </TabItem>
      <TabItem Header="Call Stack">
        <Border BorderBrush="#D0D4DB"
                BorderThickness="1"
                CornerRadius="4"
                Padding="6">
          <ListBox x:Name="CallStackList" />
        </Border>
      </TabItem>
      <TabItem Header="Breakpoints">
        <StackPanel Spacing="6">
          <Border BorderBrush="#D0D4DB"
                  BorderThickness="1"
                  CornerRadius="4"
                  Padding="6">
            <ListBox x:Name="BreakpointsList"
                     SelectionMode="Single">
              <ListBox.ItemTemplate>
                <DataTemplate x:DataType="vba:VbaBreakpoint">
                  <TextBlock Text="{Binding Display}" />
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </Border>
          <Button Content="Remove"
                  Width="90"
                  HorizontalAlignment="Left"
                  Click="OnRemoveBreakpointClick" />
        </StackPanel>
      </TabItem>
    </TabControl>

    <Grid Grid.Row="2"
          Grid.ColumnSpan="3"
          RowDefinitions="Auto,Auto,*"
          RowSpacing="6">
      <TextBlock Text="Immediate"
                 FontWeight="Bold" />
      <StackPanel Grid.Row="1"
                  Orientation="Horizontal"
                  Spacing="6">
        <TextBox x:Name="ImmediateInput"
                 Width="600"
                 FontFamily="Consolas"
                 KeyDown="OnImmediateKeyDown" />
        <Button Content="Execute"
                Width="90"
                Click="OnImmediateExecuteClick" />
      </StackPanel>
      <TextBox Grid.Row="2"
               x:Name="ImmediateOutput"
               AcceptsReturn="True"
               IsReadOnly="True"
               FontFamily="Consolas"
               TextWrapping="Wrap"
               ScrollViewer.VerticalScrollBarVisibility="Auto" />
    </Grid>
  </Grid>
</Window>
