<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:docs="clr-namespace:Vibe.Office.Documents;assembly=Vibe.Office.Documents"
        x:Class="Vibe.Word.App.MacroManagerDialog"
        Width="980"
        Height="640"
        WindowStartupLocation="CenterOwner"
        Title="Macros">
  <Grid ColumnDefinitions="220,*,200"
        RowDefinitions="Auto,*,Auto"
        ColumnSpacing="12"
        RowSpacing="10"
        Margin="12">
    <StackPanel Grid.Column="0"
                Grid.Row="0"
                Grid.RowSpan="3"
                Spacing="8">
      <TextBlock Text="Modules"
                 FontWeight="Bold" />
      <Border BorderBrush="#D0D4DB"
              BorderThickness="1"
              CornerRadius="4"
              Padding="6">
        <ListBox x:Name="ModulesList"
                 SelectionMode="Single"
                 SelectionChanged="OnModuleSelectionChanged">
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="docs:VbaModuleInfo">
              <TextBlock Text="{Binding Name}" />
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Border>
      <StackPanel Spacing="6">
        <StackPanel Orientation="Horizontal"
                    Spacing="6">
          <Button Content="New"
                  Width="80"
                  Click="OnNewModuleClick" />
          <Button Content="Rename"
                  Width="80"
                  Click="OnRenameModuleClick" />
          <Button Content="Delete"
                  Width="80"
                  Click="OnDeleteModuleClick" />
        </StackPanel>
        <StackPanel Orientation="Horizontal"
                    Spacing="6">
          <Button Content="Import"
                  Width="80"
                  Click="OnImportModuleClick" />
          <Button Content="Export"
                  Width="80"
                  Click="OnExportModuleClick" />
        </StackPanel>
      </StackPanel>
    </StackPanel>

    <TextBox x:Name="SourceEditor"
             Grid.Column="1"
             Grid.Row="0"
             Grid.RowSpan="2"
             AcceptsReturn="True"
             TextWrapping="NoWrap"
             FontFamily="Consolas"
             TextChanged="OnSourceTextChanged"
             ScrollViewer.VerticalScrollBarVisibility="Auto"
             ScrollViewer.HorizontalScrollBarVisibility="Auto" />

    <StackPanel Grid.Column="2"
                Grid.Row="0"
                Grid.RowSpan="2"
                Spacing="8">
      <TextBlock Text="Procedures"
                 FontWeight="Bold" />
      <Border BorderBrush="#D0D4DB"
              BorderThickness="1"
              CornerRadius="4"
              Padding="6">
        <ListBox x:Name="ProceduresList"
                 SelectionMode="Single"
                 DoubleTapped="OnProcedureDoubleTapped" />
      </Border>
      <StackPanel Spacing="6">
        <StackPanel Orientation="Horizontal"
                    Spacing="6">
          <Button Content="New"
                  Width="80"
                  Click="OnNewProcedureClick" />
          <Button Content="Run"
                  Width="80"
                  Click="OnRunClick" />
        </StackPanel>
      </StackPanel>
    </StackPanel>

    <StackPanel Grid.Column="1"
                Grid.Row="2"
                Grid.ColumnSpan="2"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Spacing="8">
      <Button x:Name="SaveButton"
              Content="Save"
              Width="90"
              Click="OnSaveClick" />
      <Button Content="Check"
              Width="90"
              Click="OnValidateClick" />
      <Button Content="Close"
              Width="90"
              Click="OnCloseClick" />
    </StackPanel>
  </Grid>
</Window>
