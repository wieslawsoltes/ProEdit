<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ProEdit.Ribbon.Avalonia"
        x:Class="ProEdit.Ribbon.Avalonia.RibbonColorPickerDialog"
        Width="460"
        Height="360"
        WindowStartupLocation="CenterOwner"
        Title="More Colors">
  <Window.Resources>
    <local:RibbonColorBrushConverter x:Key="RibbonColorBrushConverter" />
  </Window.Resources>
  <Grid RowDefinitions="*,Auto"
        Margin="12">
    <TabControl>
      <TabItem Header="Standard">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <ItemsControl x:Name="StandardColorsList">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <WrapPanel />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Button Width="28"
                        Height="28"
                        Margin="4"
                        ToolTip.Tip="{Binding Label}"
                        Click="OnSwatchClick">
                  <Border Background="{Binding Color, Converter={StaticResource RibbonColorBrushConverter}}"
                          BorderBrush="#404040"
                          BorderThickness="1"
                          CornerRadius="3" />
                </Button>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </TabItem>
      <TabItem Header="Custom">
        <StackPanel Spacing="12">
          <Border BorderBrush="#D0D0D0"
                  BorderThickness="1"
                  CornerRadius="4"
                  Padding="8">
            <StackPanel Spacing="8">
              <TextBlock Text="Preview"
                         FontWeight="SemiBold" />
              <Border x:Name="PreviewBorder"
                      Width="120"
                      Height="48"
                      BorderBrush="#404040"
                      BorderThickness="1"
                      CornerRadius="3" />
            </StackPanel>
          </Border>

          <Border BorderBrush="#D0D0D0"
                  BorderThickness="1"
                  CornerRadius="4"
                  Padding="8">
            <StackPanel Spacing="8">
              <TextBlock Text="Hex"
                         FontWeight="SemiBold" />
              <TextBox x:Name="HexTextBox"
                       Width="120"
                       TextChanged="OnHexChanged" />
            </StackPanel>
          </Border>

          <Border BorderBrush="#D0D0D0"
                  BorderThickness="1"
                  CornerRadius="4"
                  Padding="8">
            <StackPanel Spacing="8">
              <TextBlock Text="RGB"
                         FontWeight="SemiBold" />
              <StackPanel Orientation="Horizontal"
                          Spacing="8">
                <StackPanel>
                  <TextBlock Text="R" />
                  <TextBox x:Name="RedTextBox"
                           Width="60"
                           TextChanged="OnRgbChanged" />
                </StackPanel>
                <StackPanel>
                  <TextBlock Text="G" />
                  <TextBox x:Name="GreenTextBox"
                           Width="60"
                           TextChanged="OnRgbChanged" />
                </StackPanel>
                <StackPanel>
                  <TextBlock Text="B" />
                  <TextBox x:Name="BlueTextBox"
                           Width="60"
                           TextChanged="OnRgbChanged" />
                </StackPanel>
              </StackPanel>
            </StackPanel>
          </Border>
        </StackPanel>
      </TabItem>
    </TabControl>

    <StackPanel Grid.Row="1"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Spacing="8"
                Margin="0,12,0,0">
      <Button Content="OK"
              Width="90"
              Click="OnOkClick" />
      <Button Content="Cancel"
              Width="90"
              Click="OnCancelClick" />
    </StackPanel>
  </Grid>
</Window>
