<Project Sdk="Microsoft.NET.Sdk" TreatAsLocalProperty="_IsUnoUISolution">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <IsPackable>false</IsPackable>
    <IsUnoHead>true</IsUnoHead>
    <UnoRuntimeIdentifier>Skia</UnoRuntimeIdentifier>
  </PropertyGroup>

  <PropertyGroup>
    <_IsUnoUISolution></_IsUnoUISolution>
  </PropertyGroup>

  <PropertyGroup>
    <PackageDescription>Uno sample app showcasing ProEdit WinUICompat rich text controls.</PackageDescription>
    <PackageTags>proedit;uno;winui;sample;richtext</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Uno.WinUI" />
    <PackageReference Include="Uno.WinUI.Graphics2DSK" />
    <PackageReference Include="SkiaSharp.Views.Uno.WinUI" />
  </ItemGroup>

  <ItemGroup Condition="$([MSBuild]::IsOSPlatform('OSX'))">
    <PackageReference Include="Uno.WinUI.Runtime.Skia.MacOS" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\ProEdit.WinUICompat\ProEdit.WinUICompat.csproj" />
    <ProjectReference Include="..\ProEdit.WinUICompat.Uno\ProEdit.WinUICompat.Uno.csproj" />
    <ProjectReference Include="..\ProEdit.WinUICompat.Collaboration\ProEdit.WinUICompat.Collaboration.csproj" />
    <ProjectReference Include="..\ProEdit.FlowDocument.IO\ProEdit.FlowDocument.IO.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Page Include="**\*.xaml" Exclude="bin\**\*.xaml;obj\**\*.xaml" />
    <ApplicationDefinition Include="App\App.xaml" Condition="Exists('App\\App.xaml')" />
    <Compile Update="**\*.xaml.cs">
      <DependentUpon>%(Filename)</DependentUpon>
    </Compile>
  </ItemGroup>

  <ItemGroup>
    <UpToDateCheckInput Include="**\*.xaml" Exclude="bin\**\*.xaml;obj\**\*.xaml" />
  </ItemGroup>
</Project>
