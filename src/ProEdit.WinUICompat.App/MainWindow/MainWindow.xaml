<Window
    x:Class="ProEdit.WinUICompat.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:compat="using:ProEdit.WinUICompat.Controls"
    xmlns:vm="using:ProEdit.WinUICompat.App.ViewModels">
    <Grid RowDefinitions="Auto,*">
        <Border Background="#1C1E2B" Padding="16">
            <StackPanel Spacing="4">
                <TextBlock Text="FlowDocument + WinUICompat Rich Sample" Foreground="#F5F7FF" FontSize="20" FontWeight="SemiBold" />
                <TextBlock Text="Uno sample using ProEdit.WinUICompat.* namespaces" Foreground="#C7CAD9" FontSize="12" />
            </StackPanel>
        </Border>

        <TabView Grid.Row="1" Margin="12">
            <TabViewItem Header="XAML Sample">
                <Grid RowDefinitions="Auto,*" RowSpacing="8" Padding="8">
                    <TextBlock Text="XAML document sample parity (read-only preview)" FontWeight="SemiBold" />
                    <ScrollViewer Grid.Row="1">
                        <compat:RichTextBlock Document="{Binding XamlSampleDocument}" />
                    </ScrollViewer>
                </Grid>
            </TabViewItem>

            <TabViewItem Header="Code Sample">
                <Grid RowDefinitions="Auto,*" RowSpacing="8" Padding="8">
                    <TextBlock Text="Code-built document parity (read-only preview)" FontWeight="SemiBold" />
                    <ScrollViewer Grid.Row="1">
                        <compat:RichTextBlock Document="{Binding CodeSampleDocument}" />
                    </ScrollViewer>
                </Grid>
            </TabViewItem>

            <TabViewItem Header="RichTextBox Smoke">
                <Grid RowDefinitions="Auto,Auto,*" RowSpacing="8">
                    <Border Background="#EEF2FC"
                            BorderBrush="#D1D8EC"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="10">
                        <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,*" ColumnSpacing="8">
                            <Button Grid.Column="0" Content="Open..." Command="{Binding OpenRichTextDocumentCommand}" />
                            <Button Grid.Column="1" Content="Save As..." Command="{Binding SaveRichTextDocumentCommand}" />
                            <Button Grid.Column="2" Content="Reset" Command="{Binding ResetDocumentCommand}" />
                            <Button Grid.Column="3" Content="Load Sample" Command="{Binding LoadSampleContentCommand}" />
                            <Button Grid.Column="4" Content="Undo" Command="{Binding UndoCommand}" />
                            <Button Grid.Column="5" Content="Redo" Command="{Binding RedoCommand}" />
                            <Button Grid.Column="6" Content="Bold" Command="{Binding ToggleBoldCommand}" />
                            <Button Grid.Column="7" Content="Italic" Command="{Binding ToggleItalicCommand}" />
                            <Button Grid.Column="8" Content="Underline" Command="{Binding ToggleUnderlineCommand}" />
                            <Button Grid.Column="9" Content="Bullets" Command="{Binding ToggleBulletedListCommand}" />
                            <Button Grid.Column="10" Content="Numbering" Command="{Binding ToggleNumberedListCommand}" />
                            <Button Grid.Column="11" Content="Table" Command="{Binding InsertTableCommand}" />
                            <Button Grid.Column="12" Content="Select All" Command="{Binding SelectAllCommand}" />
                            <TextBlock Grid.Column="13"
                                       Text="{Binding StatusMessage}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Right" />
                        </Grid>
                    </Border>

                    <Border Grid.Row="1"
                            Background="#F7F9FE"
                            BorderBrush="#D1D8EC"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="10">
                        <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,*" ColumnSpacing="12">
                            <CheckBox Grid.Column="0" Content="Proofing" IsChecked="{Binding IsProofingEnabled, Mode=TwoWay}" />
                            <CheckBox Grid.Column="1" Content="Spelling" IsChecked="{Binding IsSpellingEnabled, Mode=TwoWay}" />
                            <CheckBox Grid.Column="2" Content="Grammar" IsChecked="{Binding IsGrammarEnabled, Mode=TwoWay}" />
                            <CheckBox Grid.Column="3" Content="Style" IsChecked="{Binding IsStyleEnabled, Mode=TwoWay}" />
                            <TextBlock Grid.Column="4" Text="{Binding CurrentDocumentPath}" VerticalAlignment="Center" HorizontalAlignment="Right" />
                        </Grid>
                    </Border>

                    <Border Grid.Row="2"
                            Margin="16"
                            Padding="8"
                            BorderBrush="#CBD2E6"
                            BorderThickness="1"
                            Background="#F8F9FD">
                        <compat:RichEditBox
                            MinHeight="360"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            Document="{Binding EditableDocument}"
                            IsDocumentEnabled="True"
                            IsProofingEnabled="{Binding IsProofingEnabled, Mode=TwoWay}"
                            IsSpellingEnabled="{Binding IsSpellingEnabled, Mode=TwoWay}"
                            IsGrammarEnabled="{Binding IsGrammarEnabled, Mode=TwoWay}"
                            IsStyleEnabled="{Binding IsStyleEnabled, Mode=TwoWay}" />
                    </Border>
                </Grid>
            </TabViewItem>
        </TabView>
    </Grid>
</Window>
